EXHIBITION_BADGE_URL=http://localhost:5045
EXHIBITION_ANALYTICS_URL=http://localhost:5046
EXHIBITION_NOTIFICATION_URL=http://localhost:5047
EXHIBITION_PAYMENT_URL=http://localhost:5048
EXHIBITION_INTELLIGENCE_URL=http://localhost:5049
EXHIBITION_ECONOMY_URL=http://localhost:5050
EXHIBITION_MARKETPLACE_URL=http://localhost:5051
EXHIBITION_NETWORKING_URL=http://localhost:5052
EXHIBITION_APPOINTMENT_URL=http://localhost:5053
EXHIBITION_PASSPORT_URL=http://localhost:5054
