# Exhibition Gateway Dockerfile
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install --production

# Copy source
COPY src/ ./src/

# Expose port
EXPOSE 5040

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
  CMD curl -f http://localhost:5040/health/live || exit 1

# Start
CMD ["node", "src/index.js"]
