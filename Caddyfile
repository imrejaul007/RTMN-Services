# Caddyfile for NeXha Commerce Network
# Auto HTTPS via Let's Encrypt. For local dev, run:
#   caddy run --config Caddyfile
#
# Ports:
#   :443  -> commerce-identity (8000) + sutar-mock (4799)
#   :80   -> redirect to HTTPS
#   :3000 -> Next.js portal

{
  admin off
  log {
    output file /var/log/caddy/access.log
  }
}

# Development: serve everything on localhost with self-signed
(local dev) {
  tls self_signed
  bind localhost
}

# Production: uncomment and configure your domain
# (prod) {
#   tls your@email.com
#   bind your-domain.com
# }

#commerce-identity-api {
#  @port8000 {
#    header X-Forwarded-Host api.localhost:8000
#    handle /api/* {
#      reverse_proxy localhost:8000
#    }
#  }
#}

# Root portal
localhost:3000 {
  import dev
  handle /* {
    reverse_proxy localhost:3000
  }
}

# API gateway (routes API calls to appropriate service)
localhost:8443 {
  import dev

  # commerce-identity
  handle_path /api/auth/* {
    reverse_proxy localhost:8000
  }
  handle_path /api/suppliers/* {
    reverse_proxy localhost:8000
  }
  handle_path /api/buyers/* {
    reverse_proxy localhost:8000
  }
  handle_path /api/guest-suppliers/* {
    reverse_proxy localhost:8000
  }
  handle_path /api/ratings/* {
    reverse_proxy localhost:8000
  }
  handle_path /api/corpid/* {
    reverse_proxy localhost:8000
  }

  # SUTAR mock
  handle_path /sutar/* {
    reverse_proxy localhost:4799
  }

  # Health
  handle /health {
    reverse_proxy localhost:8000
  }
}
