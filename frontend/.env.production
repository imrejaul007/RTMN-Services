# Production Environment Variables
# These will be used in Vercel deployment

# Backend API (Render - Pilot Onboarding)
NEXT_PUBLIC_API_URL=https://rtmn-pilot-onboarding.onrender.com

# Stripe (replace with real keys in Vercel dashboard)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_replace_with_real_key

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_DEMO_MODE=false
