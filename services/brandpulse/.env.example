# BrandPulse Configuration

# Server
PORT=4974
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/brandpulse

# Twitter API
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# News API
NEWS_API_KEY=your_news_api_key

# Social Media Keys
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Brand Health Thresholds
SENTIMENT_THRESHOLD_NEGATIVE=-0.3
SENTIMENT_THRESHOLD_POSITIVE=0.3
CRISIS_VOLUME_THRESHOLD=100
CRISIS_VELOCITY_THRESHOLD=50

# Integration Services
CUSTOMER_OPS_BRIDGE_URL=http://localhost:4399
CAMPAIGN_TWIN_URL=http://localhost:4705
JOURNEY_TWIN_URL=http://localhost:4705
TRUST_INTELLIGENCE_URL=http://localhost:4399

# Monitoring Intervals (milliseconds)
SOCIAL_POLL_INTERVAL=300000
HEALTH_CHECK_INTERVAL=60000
