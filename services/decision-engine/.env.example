# Server Configuration
PORT=4951
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/decision_engine

# Logging
LOG_LEVEL=info

# Multi-tenant Configuration
DEFAULT_TENANT=system

# Risk Thresholds
RISK_THRESHOLD_LOW=30
RISK_THRESHOLD_MEDIUM=60
RISK_THRESHOLD_HIGH=80

# Value Thresholds
VALUE_THRESHOLD_SILVER=1000
VALUE_THRESHOLD_GOLD=5000
VALUE_THRESHOLD_PLATINUM=10000

# Approval Limits (in cents)
APPROVAL_LIMIT_TIER1=5000
APPROVAL_LIMIT_TIER2=25000
APPROVAL_LIMIT_TIER3=100000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://rtmn-pilot-portal.vercel.app

# Event Bus Integration
EVENT_BUS_URL=http://localhost:4510

# Service Registry
SERVICE_REGISTRY_URL=http://localhost:4399
