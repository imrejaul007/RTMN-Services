# Finance Copilot Service Configuration
# Copy to .env and fill in your values

# Service Port
PORT=4930

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/finance_copilot

# OpenAI API Key (for AI-powered insights)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Service Registry
SERVICE_REGISTRY_URL=http://localhost:4399

# Optional: Event Bus
EVENT_BUS_URL=http://localhost:4510

# Logging
LOG_LEVEL=info
