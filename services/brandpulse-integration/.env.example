# BrandPulse Integration Service Configuration

# Server
PORT=4974
NODE_ENV=development

# BrandPulse API
BRANDPULSE_API_URL=http://localhost:4970
BRANDPULSE_API_KEY=your_brandpulse_api_key

# Campaign Twin (Digital Twin Service)
CAMPAIGN_TWIN_URL=http://localhost:4705/api/campaigns
CAMPAIGN_TWIN_API_KEY=your_campaign_twin_key

# Journey Twin (Digital Twin Service)
JOURNEY_TWIN_URL=http://localhost:4705/api/journeys
JOURNEY_TWIN_API_KEY=your_journey_twin_key

# Trust Intelligence
TRUST_INTELLIGENCE_URL=http://localhost:4310
TRUST_INTELLIGENCE_API_KEY=your_trust_intelligence_key

# Customer Operations OS
CUSTOMER_OPS_URL=http://localhost:4990
CUSTOMER_OPS_API_KEY=your_customer_ops_key

# Executive Dashboard
DASHBOARD_URL=http://localhost:4000/api/dashboard
DASHBOARD_API_KEY=your_dashboard_key

# Event Bus (for pub/sub)
EVENT_BUS_URL=http://localhost:4510
EVENT_BUS_API_KEY=your_event_bus_key

# Webhooks
WEBHOOK_SECRET=your_webhook_secret
