# Crowd Intelligence Service Configuration

# Service
PORT=4983
NODE_ENV=development

# Service Registry
SERVICE_NAME=crowd-intelligence
SERVICE_VERSION=1.0.0

# Pattern Detection
ANOMALY_THRESHOLD=2.5
MIN_SAMPLE_SIZE=10
DETECTION_WINDOW_MS=60000

# Trend Analysis
TREND_INTERVAL_MS=300000
TREND_HISTORY_HOURS=24

# Outbreak Detection
OUTBREAK_THRESHOLD=3.0
OUTBREAK_WINDOW_MS=300000
ALERT_COOLDOWN_MS=600000

# Integration
EVENT_BUS_URL=http://localhost:4510
EVENT_BUS_ENABLED=true

# Logging
LOG_LEVEL=info