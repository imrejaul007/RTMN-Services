# Server Configuration
PORT=4898
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/cross_ecosystem_bridge

# RTMN Service URLs

# HOJAI AI Services
HOJAI_API_URL=http://localhost:4500
HOJAI_GENIE_URL=http://localhost:4501
HOJAI_MEMORY_URL=http://localhost:4703

# REZ Services
REZ_CONSUMER_URL=http://localhost:3000
REZ_MERCHANT_URL=http://localhost:4800
REZ_POS_URL=http://localhost:4800
REZ_ORDERS_URL=http://localhost:4801
REZ_PAYMENTS_URL=http://localhost:4803
REZ_WALLET_URL=http://localhost:4004

# StayOwn Hospitality Services
STAYOWN_API_URL=http://localhost:6000
STAYOWN_HOTEL_OS_URL=http://localhost:5025
STAYOWN_BOOKING_URL=http://localhost:6001

# AdBazaar Services
ADBazaar_API_URL=http://localhost:4056
ADBazaar_CRM_URL=http://localhost:4056
ADBazaar_ADS_URL=http://localhost:5000

# CorpID Services
CORPID_API_URL=http://localhost:4702
CORPID_VERIFY_URL=http://localhost:4702/verify

# Integration Hub
EVENT_BUS_URL=http://localhost:4510
SERVICE_REGISTRY_URL=http://localhost:4399
GRAPHQL_FEDERATION_URL=http://localhost:4000

# Security
JWT_SECRET=your-jwt-secret-change-in-production

# Multi-tenant Configuration
DEFAULT_TENANT=rtmn
ENABLE_MULTI_TENANT=true

# Feature Flags
ENABLE_IDENTITY_RESOLUTION=true
ENABLE_OFFER_GENERATION=true
ENABLE_ENGAGEMENT_ANALYTICS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
