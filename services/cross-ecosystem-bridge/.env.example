DEV_SERVICE_REGISTRY_URL=http://localhost:4399
DEV_GRAPHQL_FEDERATION_URL=http://localhost:4000

# ============================================
# PRODUCTION URLS (Render/Vercel Deployment)
# ============================================

# MongoDB Atlas (Production)
MONGODB_URI=mongodb+srv://your-mongodb-atlas-uri

# HOJAI AI Services (Production)
HOJAI_API_URL=https://hojai-api.onrender.com
HOJAI_GENIE_URL=https://hojai-genie.onrender.com
HOJAI_MEMORY_URL=https://memory-os.onrender.com

# REZ Services (Production)
REZ_CONSUMER_URL=https://rez-consumer.onrender.com
REZ_MERCHANT_URL=https://rez-merchant.onrender.com
REZ_POS_URL=https://rez-merchant.onrender.com
REZ_ORDERS_URL=https://rez-orders.onrender.com
REZ_PAYMENTS_URL=https://rez-payments.onrender.com
REZ_WALLET_URL=https://rez-wallet.onrender.com

# StayOwn Hospitality Services (Production)
STAYOWN_API_URL=https://hotel-ota-api.onrender.com
STAYOWN_HOTEL_OS_URL=https://hotel-os.onrender.com
STAYOWN_BOOKING_URL=https://hotel-ota-api.onrender.com

# AdBazaar Services (Production)
ADBazaar_API_URL=https://adbazaar-api.onrender.com
ADBazaar_CRM_URL=https://adbazaar-crm.onrender.com
ADBazaar_ADS_URL=https://adbazaar-ads.onrender.com

# CorpID Services (Production)
CORPID_API_URL=https://corpid-service.onrender.com
CORPID_VERIFY_URL=https://corpid-service.onrender.com/verify

# Integration Hub (Production)
EVENT_BUS_URL=https://rez-event-bus.onrender.com
SERVICE_REGISTRY_URL=https://rez-ecosystem-connector.onrender.com
GRAPHQL_FEDERATION_URL=https://rez-graphql-federation.onrender.com

# ============================================
# SHARED (Both Dev & Prod)
# ============================================

# Security
JWT_SECRET=your-jwt-secret-change-in-production

# Multi-tenant Configuration
DEFAULT_TENANT=rtmn
ENABLE_MULTI_TENANT=true

# Feature Flags
ENABLE_IDENTITY_RESOLUTION=true
ENABLE_OFFER_GENERATION=true
ENABLE_ENGAGEMENT_ANALYTICS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
