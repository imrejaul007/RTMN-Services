DEV_HOJAI_API_URL=http://localhost:4500
DEV_HOJAI_GENIE_URL=http://localhost:4501
DEV_HOJAI_MEMORY_URL=http://localhost:4703

# REZ Services (Dev)
DEV_REZ_CONSUMER_URL=http://localhost:3000
DEV_REZ_MERCHANT_URL=http://localhost:4800
DEV_REZ_POS_URL=http://localhost:4800
DEV_REZ_ORDERS_URL=http://localhost:4801
DEV_REZ_PAYMENTS_URL=http://localhost:4803
DEV_REZ_WALLET_URL=http://localhost:4004

# StayOwn Hospitality Services (Dev)
DEV_STAYOWN_API_URL=http://localhost:3000
DEV_STAYOWN_HOTEL_OS_URL=http://localhost:5025
DEV_STAYOWN_BOOKING_URL=http://localhost:6010

# AdBazaar Services (Dev)
