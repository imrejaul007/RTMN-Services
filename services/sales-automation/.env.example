# Server
PORT=5183
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Follow-up Settings
FOLLOWUP_INITIAL_DELAY_MINUTES=30
FOLLOWUP_MAX_ATTEMPTS=5
FOLLOWUP_ESCALATION_THRESHOLD=3

# Routing Settings
ROUTING_DEFAULT_QUEUE=general
ROUTING_LEAD_THRESHOLD_HIGH=80
ROUTING_LEAD_THRESHOLD_MEDIUM=50

# Escalation Settings
ESCALATION_RESPONSE_TIME_MINUTES=60
ESCALATION_URGENT_THRESHOLD_MINUTES=15
ESCALATION_MAX_LEVELS=4

# Workflow Settings
WORKFLOW_CHECK_INTERVAL_SECONDS=60
WORKFLOW_BATCH_SIZE=50

# External Services
EVENT_BUS_URL=http://localhost:4510
SERVICE_REGISTRY_URL=http://localhost:4399
