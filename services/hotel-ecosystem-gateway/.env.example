# ===========================================
# PRODUCTION URLS
# ===========================================

HOTEL_OS_URL=https://hotel-os.onrender.com
REZ_MERCHANT_URL=https://rez-merchant.onrender.com
REZ_BOOKING_URL=https://rez-booking.onrender.com
REZ_MIND_HOTEL_URL=https://rez-mind-hotel.onrender.com
