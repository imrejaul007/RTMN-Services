# Pilot Onboarding Service
PORT=4399
NODE_ENV=development
LOG_LEVEL=info

# Database
MONGO_URI=mongodb://localhost:27017/rtmn_onboarding
# In-memory fallback: leave MONGO_URI empty to use built-in Map store

# JWT (REQUIRED in production - generate with: openssl rand -hex 32)
JWT_SECRET=replace_me_with_64_char_hex
JWT_EXPIRES_IN=7d

# CORS (comma-separated list of allowed origins, or leave empty for localhost only)
ALLOWED_ORIGINS=http://localhost:3000,https://rtmn-pilot-portal.vercel.app

# RABTUL
RABTUL_AUTH_URL=http://localhost:4002
RABTUL_PAYMENT_URL=http://localhost:4001
RABTUL_API_KEY=replace_me

# CorpID
CORPID_URL=http://localhost:4702
CORPID_API_KEY=replace_me

# Email (Resend)
RESEND_API_KEY=re_replace_me
EMAIL_FROM=noreply@rtmn.io
EMAIL_REPLY_TO=support@rtmn.io

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Sentry (optional - error tracking)
SENTRY_DSN=replace_me
SENTRY_TRACES_SAMPLE_RATE=0.1

# Public URL for verification links (use your Vercel domain in production)
PUBLIC_URL=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# 24 Industry OS URLs (update with production endpoints)
RESTAURANT_OS_URL=http://localhost:5010
