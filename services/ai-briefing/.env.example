# AI Briefing Service Configuration
PORT=4897
MONGODB_URI=mongodb://localhost:27017/ai-briefing

# Scheduling
BRIEFING_SCHEDULE_HOUR=6
BRIEFING_SCHEDULE_MINUTE=0

# Multi-tenant
DEFAULT_TENANT_ID=default

# Email Configuration (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=briefings@example.com
SMTP_PASS=your-password
EMAIL_FROM=briefings@rtmn.io

# WhatsApp Configuration
WHATSAPP_API_URL=https://api.whatsapp.example.com
WHATSAPP_API_TOKEN=your-whatsapp-token

# Slack Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_BOT_TOKEN=xoxb-your-token

# External Service URLs (for integration)
GOAL_OS_URL=http://localhost:4242
MEMORY_OS_URL=http://localhost:4703
CORPID_SERVICE_URL=http://localhost:4702
REZ_EVENT_BUS_URL=http://localhost:4510

# Risk Thresholds
RISK_THRESHOLD_HIGH=80
RISK_THRESHOLD_MEDIUM=50
RISK_THRESHOLD_LOW=25

# Logger
LOG_LEVEL=info
