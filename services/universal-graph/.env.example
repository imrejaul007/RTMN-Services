# Universal Business Graph Engine
PORT=4937

# MongoDB Connection (for persistence)
MONGODB_URI=mongodb://localhost:27017/universal_graph

# Neo4j Connection (for graph traversal)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Service Discovery
SERVICE_NAME=universal-graph
SERVICE_URL=http://localhost:4937

# Logging
LOG_LEVEL=info
