# Sales Sync Service Configuration
PORT=5182
NODE_ENV=development

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# SalesMind Integration
SALESMIND_API_URL=http://localhost:4250
SALESMIND_API_KEY=your_salesmind_api_key

# Sales OS Integration
SALESOS_API_URL=http://localhost:5055
SALESOS_API_KEY=your_salesos_api_key

# Customer Ops Integration
CUSTOMEROPS_API_URL=http://localhost:4780
CUSTOMEROPS_API_KEY=your_customerops_api_key

# BrandPulse Integration
BRANDPULSE_API_URL=http://localhost:5057
BRANDPULSE_API_KEY=your_brandpulse_api_key

# Event Bus (for real-time sync)
EVENT_BUS_URL=http://localhost:4510
EVENT_BUS_TOKEN=your_event_bus_token

# Sync Configuration
SYNC_INTERVAL_MS=30000
CONFLICT_STRATEGY=last-write-wins
MAX_RETRY_ATTEMPTS=3
BATCH_SIZE=100

# Audit Configuration
AUDIT_RETENTION_DAYS=90
