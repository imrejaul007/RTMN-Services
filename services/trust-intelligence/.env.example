# Trust Intelligence Service Configuration
PORT=4953
MONGODB_URI=mongodb://localhost:27017/trust_intelligence

# Service Discovery
SERVICE_NAME=trust-intelligence
SERVICE_VERSION=1.0.0

# Security
JWT_SECRET=your-jwt-secret-here
API_KEY=your-api-key-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Trust Score Weights (percentages)
TRUST_WEIGHT_TRANSACTIONS=30
TRUST_WEIGHT_VERIFICATIONS=25
TRUST_WEIGHT_BEHAVIOR=20
TRUST_WEIGHT_HISTORY=15
TRUST_WEIGHT_NETWORK=10

# Fraud Detection
FRAUD_SUSPICIOUS_THRESHOLD=0.7
FRAUD_CRITICAL_THRESHOLD=0.9
MAX_FAILED_ATTEMPTS=5

# Multi-tenant
DEFAULT_TENANT=default
