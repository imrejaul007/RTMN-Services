# AssetMind Integration Service Configuration
# Port: 4969

# Service
PORT=4969
SERVICE_NAME=assetmind-integration
NODE_ENV=development

# Customer Operations Bridge
CUSTOMER_OPS_URL=http://localhost:4399

# Industry Twin (Finance) - Deal Twin
INDUSTRY_TWIN_URL=http://localhost:3018

# Payment Twin
PAYMENT_TWIN_URL=http://localhost:4004

# Customer Twin
CUSTOMER_TWIN_URL=http://localhost:3017

# Event Bus
EVENT_BUS_URL=http://localhost:4510

# Service Registry
SERVICE_REGISTRY_URL=http://localhost:4399

# Logging
LOG_LEVEL=info
