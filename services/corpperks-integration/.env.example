# CorpPerks Integration Service Configuration

# Server Configuration
PORT=4968
NODE_ENV=development

# Service URLs
EMPLOYEE_TWIN_URL=http://localhost:3011
PAYMENT_TWIN_URL=http://localhost:3012
INDUSTRY_TWIN_URL=http://localhost:4705

# Event Bus
EVENT_BUS_URL=http://localhost:4510

# Service Registry
SERVICE_REGISTRY_URL=http://localhost:4399

# Authentication
JWT_SECRET=your-jwt-secret-here

# External CorpPerks API (if using external service)
CORPPERKS_API_URL=https://api.corpperks.example.com
CORPPERKS_API_KEY=your-corpperks-api-key

# Logging
LOG_LEVEL=info
