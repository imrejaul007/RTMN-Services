# Voice Twin Service Configuration
# Port for the service
PORT=4876

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/voice-twin

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret_here

# OpenAI Configuration (for Whisper transcription and analysis)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Service URLs
CUSTOMER_TWIN_URL=http://localhost:3017
EVENT_BUS_URL=http://localhost:4510

# Logging
LOG_LEVEL=info

# Environment
NODE_ENV=development
