# Executive Dashboard Service Configuration

# Server Configuration
PORT=4896
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/executive_dashboard

# Service Configuration
SERVICE_NAME=executive-dashboard
SERVICE_VERSION=1.0.0

# API Keys (for external service integrations)
INTERNAL_API_KEY=your-internal-api-key-here

# Event Bus Configuration
EVENT_BUS_URL=http://localhost:4510
EVENT_BUS_API_KEY=your-event-bus-api-key

# Alert Configuration
ALERT_THRESHOLD_HIGH=80
ALERT_THRESHOLD_MEDIUM=50
ALERT_THRESHOLD_LOW=20

# Multi-tenant Configuration
DEFAULT_TENANT=default

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4896

# Logging
LOG_LEVEL=info
