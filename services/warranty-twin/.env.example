# Warranty Twin Service Configuration
# ===================================

# Service Port
PORT=4905

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/warranty-twin

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4905

# Service Metadata
SERVICE_NAME=warranty-twin
SERVICE_VERSION=1.0.0

# Logging
LOG_LEVEL=info
