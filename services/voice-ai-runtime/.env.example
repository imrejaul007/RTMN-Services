# Voice AI Runtime Configuration
PORT=4876
NODE_ENV=development

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI Configuration
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOICE_MODEL=ft-voice-2024-06-17
WHISPER_MODEL=whisper-1

# Service Integrations
TICKET_ENGINE_URL=http://localhost:4300
CUSTOMER_TWIN_URL=http://localhost:3017
AGENT_COPILOT_URL=http://localhost:4765
MEMORY_OS_URL=http://localhost:4703

# Voice Settings
MAX_CALL_DURATION=1800
TRANSFER_TIMEOUT=30
SILENCE_TIMEOUT=10
BEEP_ON_TRANSFER=true

# WebSocket
WS_HEARTBEAT_INTERVAL=30000
