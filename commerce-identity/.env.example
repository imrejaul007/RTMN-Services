# =============================================================================
# commerce-identity — Environment Variables Template
# =============================================================================
# Copy this file to `.env` and fill in the values for your environment.
#
# SECURITY: Do NOT commit your real `.env` file. The root `.gitignore` already
# excludes it. The dev values below are placeholders that MUST be replaced
# before any production deploy.
#
# To generate strong secrets:
#   openssl rand -hex 32     # 64-char hex string — use for JWT_SECRET and INTERNAL_API_KEY
# =============================================================================

# ---- Server ---------------------------------------------------------------
PORT=8000
NODE_ENV=development              # development | production
LOG_LEVEL=info                    # error | warn | info | http | verbose | debug | silly

# ---- Database -------------------------------------------------------------
# Production: use MongoDB Atlas or a managed instance with TLS.
MONGODB_URI=mongodb://localhost:27017/nexha_commerce_identity

# ---- CORS -----------------------------------------------------------------
# Comma-separated list of allowed origins for the CORS policy.
# Dev: http://localhost:3000 (Next.js portal dev server)
# Prod: https://your-portal.vercel.app
# DO NOT use wildcards in production — see NEXHA-DEEP-AUDIT.md S-2.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- SUTAR OS Integration (RTMN trust layer) -----------------------------
# In dev: point at the local sutar-mock service (port 4799).
# In prod: point at the real SUTAR endpoints. See DEPLOY.md for the full list.
#
# Recommended: set only SUTAR_BASE_URL and let the service derive the rest.
# If you set per-service URLs, ALL FIVE must be set (no implicit derivation).
SUTAR_BASE_URL=http://localhost:4799
SUTAR_IDENTITY_URL=http://localhost:4799
SUTAR_REPUTATION_URL=http://localhost:4799
SUTAR_DECISION_URL=http://localhost:4799
SUTAR_EVENT_BUS_URL=http://localhost:4799

# ---- JWT (real auth) ------------------------------------------------------
# PRODUCTION: REQUIRED. Must be a strong random value (openssl rand -hex 32).
# Dev:        The service will throw on startup if this is the default value
#             (see Phase 3 fix — fallbacks removed in production builds).
JWT_SECRET=dev-secret-change-me-in-production-please   # <-- REPLACE
JWT_EXPIRES_IN=7d                                       # m | h | d | w
JWT_ISSUER=nexha-commerce-identity
JWT_AUDIENCE=nexha-portal

# ---- Service-to-service auth ---------------------------------------------
# PRODUCTION: REQUIRED. Shared secret for x-internal-key header.
INTERNAL_API_KEY=change-me-in-production                # <-- REPLACE

# ---- Guest onboarding ----------------------------------------------------
GUEST_ID_PREFIX=GST-
GUEST_DEFAULT_VALIDITY_DAYS=30
# WHATSAPP_VERIFICATION_REQUIRED is declared in render.yaml for documentation
# purposes but the field is always enforced (no conditional skip). Kept here
# so the deployment config matches the source intent.

# ---- WhatsApp Business API -----------------------------------------------
# Leave WHATSAPP_PROVIDER empty for dev (OTP is logged to console + event bus).
# Set to 'meta' or 'twilio' for production.
WHATSAPP_PROVIDER=
# Meta WhatsApp Business Cloud API:
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Twilio WhatsApp:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# =============================================================================
# Rotation checklist (Phase 2 of NEXHA-DEEP-AUDIT.md):
#   [ ] JWT_SECRET rotated
#   [ ] INTERNAL_API_KEY rotated
#   [ ] MONGODB_URI uses a strong password (not in this file)
#   [ ] ALLOWED_ORIGINS limited to actual production domains
#   [ ] SUTAR_*_URLs point at real SUTAR (not sutar-mock)
#   [ ] WHATSAPP_PROVIDER set + credentials filled (or explicitly blank for dev)
# =============================================================================
