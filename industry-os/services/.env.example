# RTMN Workforce OS - Environment Configuration

# ===========================================
# AUTH & SECURITY
# ===========================================

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-here

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,https://peopleos.rtmn.com,https://talentai.rtmn.com

# ===========================================
# AI PROVIDERS
# ===========================================

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ===========================================
# FOUNDATION SERVICES
# ===========================================

# CorpID (Port 4702)
CORPID_URL=http://localhost:4702

# Memory OS (Port 4703)
MEMORY_OS_URL=http://localhost:4703

# TwinOS Hub (Port 4705)
TWINOS_URL=http://localhost:4705

# Event Bus (Port 4510)
EVENT_BUS_URL=http://localhost:4510

# ===========================================
# WORKFORCE OS SUITE
# ===========================================

# Workforce OS (Port 5065)
WORKFORCE_OS_URL=http://localhost:5065

# Talent OS (Port 5066)
TALENT_OS_URL=http://localhost:5066

# Learning OS (Port 5068)
LEARNING_OS_URL=http://localhost:5068

# Organization OS (Port 5072)
ORG_OS_URL=http://localhost:5072

# Workforce Intelligence (Port 5073)
INTELLIGENCE_URL=http://localhost:5073

# Cross-OS Integration Hub (Port 5085)
CROSS_OS_URL=http://localhost:5085

# ===========================================
# DATABASE
# ===========================================

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/workforce
MONGODB_URI_TALENT=mongodb://localhost:27017/talent
MONGODB_URI_LEARNING=mongodb://localhost:27017/learning
MONGODB_URI_ORG=mongodb://localhost:27017/organization
MONGODB_URI_INTELLIGENCE=mongodb://localhost:27017/intelligence

# ===========================================
# REDIS
# ===========================================

REDIS_URL=redis://localhost:6379

# ===========================================
# MONITORING
# ===========================================

# Grafana
GRAFANA_PASSWORD=admin

# ===========================================
# INDUSTRY OS URLs
# ===========================================

HOSPITALITY_OS_URL=http://localhost:5010
HEALTHCARE_OS_URL=http://localhost:5020
HOTEL_OS_URL=http://localhost:5025
RETAIL_OS_URL=http://localhost:5030
LEGAL_OS_URL=http://localhost:5035
EDUCATION_OS_URL=http://localhost:5060
AUTOMOTIVE_OS_URL=http://localhost:5080
BEAUTY_OS_URL=http://localhost:5090
FITNESS_OS_URL=http://localhost:5110
REALESTATE_OS_URL=http://localhost:5230
SALES_OS_URL=http://localhost:5055
MEDIA_OS_URL=http://localhost:5600
TRAVEL_OS_URL=http://localhost:5190
GAMING_OS_URL=http://localhost:5120
GOVERNMENT_OS_URL=http://localhost:5130
HOMESERVICES_OS_URL=http://localhost:5140
MANUFACTURING_OS_URL=http://localhost:5150
NONPROFIT_OS_URL=http://localhost:5160
PROFESSIONAL_OS_URL=http://localhost:5170
SPORTS_OS_URL=http://localhost:5180
ENTERTAINMENT_OS_URL=http://localhost:5200
CONSTRUCTION_OS_URL=http://localhost:5210
FINANCIAL_OS_URL=http://localhost:5220
TRANSPORT_OS_URL=http://localhost:5240

# ===========================================
# PRODUCTION SPECIFIC
# ===========================================

# NODE_ENV (development/production)
NODE_ENV=development

# LOG_LEVEL (info/debug/error)
LOG_LEVEL=info

# ===========================================
# PAYMENT & BILLING (if needed)
# ===========================================

# Stripe Keys
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===========================================
# EMAIL (Resend)
# ===========================================

RESEND_API_KEY=re_your-resend-key

# ===========================================
# DEPLOYMENT
# ===========================================

# Vercel (for frontend)
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id

# Render (for backend)
RENDER_API_KEY=your-render-api-key
