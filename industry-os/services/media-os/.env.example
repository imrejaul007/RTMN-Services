# Media OS Environment Variables
# Copy to .env and fill in values

# Server
PORT=5600
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/media-os

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# RTMN Services
HOJAI_AI_URL=http://localhost:4560
ADBAZAAR_DSP_URL=http://localhost:4990
ADBAZAAR_SSP_URL=http://localhost:4980
ADBAZAAR_INTENT_URL=http://localhost:4800
ADBAZAAR_ATTRIBUTION_URL=http://localhost:4950
CORPID_URL=http://localhost:4702
MEMORY_OS_URL=http://localhost:4703
TWIN_OS_URL=http://localhost:4705
EVENT_BUS_URL=http://localhost:4510
SUTAR_OS_URL=http://localhost:4140
RABTUL_WALLET_URL=http://localhost:4004

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
LOG_TO_FILE=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Streaming
CDN_URL=https://cdn.rtmn.in
