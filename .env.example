# =============================================================================
# RTMN-Services - Master Environment Configuration
# Generated: 2026-06-15
# Copy to .env and fill in real values. NEVER commit .env
# =============================================================================

# -----------------------------------------------------------------------------
# CORE
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
PUBLIC_URL=http://localhost:3000
API_GATEWAY_PORT=4399
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# -----------------------------------------------------------------------------
# DATABASE (MongoDB / Redis)
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/rtmn
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# -----------------------------------------------------------------------------
# SECRETS (generate with: openssl rand -hex 32)
# -----------------------------------------------------------------------------
JWT_SECRET=replace_me_with_64_char_hex
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=replace_me_with_32_byte_base64
SESSION_SECRET=replace_me

# -----------------------------------------------------------------------------
# RABTUL - Auth, Payment, Wallet, Notification (ports 4001-4040)
# -----------------------------------------------------------------------------
RABTUL_AUTH_URL=http://localhost:4002
RABTUL_PAYMENT_URL=http://localhost:4001
RABTUL_WALLET_URL=http://localhost:4004
RABTUL_NOTIFY_URL=http://localhost:4005
RABTUL_API_KEY=replace_me
RABTUL_WEBHOOK_SECRET=replace_me

# -----------------------------------------------------------------------------
# HOJAI AI - Genie, SUTAR OS, Vector, RAG
# -----------------------------------------------------------------------------
HOJAI_GENIE_URL=http://localhost:4501
HOJAI_VECTOR_URL=http://localhost:4502
HOJAI_RAG_URL=http://localhost:4503
HOJAI_AGENT_URL=http://localhost:4504
HOJAI_API_KEY=replace_me
OPENAI_API_KEY=replace_me
ANTHROPIC_API_KEY=replace_me

# -----------------------------------------------------------------------------
# CorpID, MemoryOS, GoalOS, Decision Engine (Foundation)
