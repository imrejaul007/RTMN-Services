# -----------------------------------------------------------------------------
# ONBOARDING & PAYMENTS
# -----------------------------------------------------------------------------
# Stripe (use test keys for pilot)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_PILOT_HO=price_replace_me   # $99/mo Hotel pilot
STRIPE_PRICE_GROWTH=price_replace_me      # $499/mo Growth
STRIPE_PRICE_ENTERPRISE=price_replace_me  # $2999/mo Enterprise

# RABTUL wallet bridge
RABTUL_WALLET_API_KEY=replace_me
WALLET_DEFAULT_CURRENCY=USD

# -----------------------------------------------------------------------------
# EMAIL & SMS (verification, notifications)
# -----------------------------------------------------------------------------
# Resend (free tier: 3,000 emails/mo)
RESEND_API_KEY=re_replace_me
EMAIL_FROM=noreply@rtmn.io
EMAIL_REPLY_TO=support@rtmn.io
SUPPORT_EMAIL=support@rtmn.io

# Twilio (optional, paid)
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_FROM_NUMBER=+15555555555

# -----------------------------------------------------------------------------
# MONITORING & OBSERVABILITY
# -----------------------------------------------------------------------------
# Sentry (free tier: 5K events/mo)
SENTRY_DSN=https://replace_me@sentry.io/123
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development

# Logging
LOG_FORMAT=json          # json | pretty
LOG_DESTINATION=stdout  # stdout | file

# Uptime monitoring
UPTIME_ROBOT_API_KEY=replace_me
STATUS_PAGE_URL=https://status.rtmn.io

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=10

# -----------------------------------------------------------------------------
# DEPLOYMENT (Railway / Render / Fly.io)
# -----------------------------------------------------------------------------
RAILWAY_TOKEN=replace_me
RAILWAY_PROJECT_ID=replace_me
DOCKER_REGISTRY=ghcr.io
GITHUB_TOKEN=replace_me

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
ENABLE_PILOT_HOTEL=true
ENABLE_PAYMENTS=true
ENABLE_EMAIL_VERIFY=true
ENABLE_SMS_VERIFY=false
ENABLE_SENTRY=true
ENABLE_ANALYTICS=false
