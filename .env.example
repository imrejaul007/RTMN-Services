STAYOWN_AUTH_URL=http://localhost:6011
STAYOWN_DASHBOARD_URL=http://localhost:6012
STAYOWN_PAYMENT_URL=http://localhost:6013
STAYOWN_HOUSEKEEPING_URL=http://localhost:6014
STAYOWN_GUEST_TWIN_URL=http://localhost:6015
