# =============================================================================
# RTMN-Services - Master Environment Configuration
# Generated: 2026-06-17
# Copy to .env and fill in real values. NEVER commit .env
# =============================================================================

# -----------------------------------------------------------------------------
# CORE
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
PUBLIC_URL=http://localhost:3000
API_GATEWAY_PORT=4399
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003

# -----------------------------------------------------------------------------
# DATABASE (MongoDB / Redis)
# -----------------------------------------------------------------------------
# Development
DEV_MONGO_URI=mongodb://localhost:27017/rtmn
DEV_REDIS_URL=redis://localhost:6379
# Production
MONGO_URI=mongodb+srv://your-mongodb-atlas-uri
REDIS_URL=redis://redis-cloud-host:6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true

