{
  "version": 2,
  "buildCommand": "npm install",
  "installCommand": "npm install",
  "framework": "express",
  "regions": ["sin1"],
  "env": {
    "NODE_ENV": "production"
  },
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/health",
      "dest": "/api/index.js"
    }
  ]
}
