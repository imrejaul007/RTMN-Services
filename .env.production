# ===================================================================
# RTMN Production Environment Configuration
# ===================================================================
# Generated: June 15, 2026
# Use: For production deployment
# ===================================================================

# ---- General ----
NODE_ENV=production
LOG_LEVEL=info
APP_VERSION=1.0.0

# ---- Server ----
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=https://app.rtmn.com,https://admin.rtmn.com

# ---- Database (MongoDB) ----
MONGODB_URI=mongodb://mongo:27017/rtmn
MONGODB_USER=rtmn_prod
MONGODB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
MONGODB_DATABASE=rtmn_production

# ---- Cache (Redis) ----
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ---- Authentication & Security ----
JWT_SECRET=CHANGE_ME_JWT_SECRET_64_CHAR_MIN
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
SESSION_SECRET=CHANGE_ME_SESSION_SECRET

# ---- RABTUL Services (Internal) ----
RABTUL_AUTH_URL=http://rez-auth-service:4002
RABTUL_PAYMENT_URL=http://rez-payment-service:4001
RABTUL_WALLET_URL=http://rez-wallet-service:4004
RABTUL_NOTIFICATION_URL=http://rez-notification-service:4005

# ---- Integration Gateway ----
INTEGRATION_GATEWAY_URL=http://rez-ecosystem-connector:4399
EVENT_BUS_URL=http://rez-event-bus:4510
GRAPHQL_FEDERATION_URL=http://rez-graphql-federation:4000

# ---- HOJAI AI Services ----
HOJAI_BUSINESS_COPILOT_URL=http://hojai-business-copilot:4600
HOJAI_BRANDPULSE_URL=http://hojai-company-intelligence:4770
HOJAI_SKILLNET_URL=http://hojai-skillnet:5130
HOJAI_VOICE_URL=http://hojai-voice-os:4760

# ---- SutAR OS Services ----
SUTAR_GATEWAY_URL=http://sutar-gateway:4140
SUTAR_INTENT_BUS_URL=http://sutar-intent-bus:4154
SUTAR_AGENT_NETWORK_URL=http://sutar-agent-network:4155
SUTAR_DECISION_ENGINE_URL=http://sutar-decision-engine:4240
SUTAR_ECONOMY_URL=http://sutar-economy-os:4251
SUTAR_TRUST_ENGINE_URL=http://sutar-trust-engine:4180

# ---- RABTUL Business Services ----
REZ_MANUFACTURING_URL=http://rez-manufacturing-os:4330
REZ_FRANCHISE_URL=http://rez-franchise-os:4310
REZ_DISTRIBUTION_URL=http://rez-distribution-os:4300
REZ_CONTRACT_URL=http://rez-contract-management:4320
REZ_WORKFLOW_URL=http://rez-workflow-executor:4331
REZ_KNOWLEDGE_URL=http://rez-knowledge-search:4332
REZ_MEMORY_URL=http://rez-memory-cloud:4333
REZ_GRAPH_URL=http://rez-graph-service:4334
REZ_AGENT_MARKETPLACE_URL=http://rez-agent-marketplace:4335
REZ_OBSERVABILITY_URL=http://rez-agent-observability:4336
REZ_HR_HUB_URL=http://rez-unified-hub:4301

# ---- Email (SMTP) ----
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_SENDGRID_KEY
SMTP_FROM=noreply@rtmn.com

# ---- SMS (Twilio) ----
TWILIO_ACCOUNT_SID=CHANGE_ME_TWILIO_SID
TWILIO_AUTH_TOKEN=CHANGE_ME_TWILIO_TOKEN
TWILIO_PHONE_NUMBER=+1234567890

# ---- Payment (Stripe) ----
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ---- Cloud Storage (AWS S3) ----
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET
AWS_REGION=us-east-1
AWS_S3_BUCKET=rtmn-production-uploads
AWS_CLOUDFRONT_URL=https://cdn.rtmn.com

# ---- LLM Providers ----
OPENAI_API_KEY=sk-OPENAI_KEY_HERE
ANTHROPIC_API_KEY=sk-ant-ANTHROPIC_KEY_HERE
GOOGLE_AI_API_KEY=GOOGLE_AI_KEY_HERE

# ---- Monitoring ----
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
SENTRY_DSN=https://CHANGE_ME@sentry.io/123

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- Feature Flags ----
FEATURE_SKILLNET_ENABLED=true
FEATURE_AGENT_MARKETPLACE_ENABLED=true
FEATURE_WORKFLOW_BUILDER_ENABLED=true
FEATURE_INDUSTRY_OS_ENABLED=true

# ---- Domain & URLs ----
PUBLIC_URL=https://api.rtmn.com
APP_URL=https://app.rtmn.com
ADMIN_URL=https://admin.rtmn.com
DOCS_URL=https://docs.rtmn.com

# ---- SSL/TLS ----
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/rtmn.crt
SSL_KEY_PATH=/etc/ssl/private/rtmn.key

# ---- Backup ----
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_S3_BUCKET=rtmn-production-backups
BACKUP_RETENTION_DAYS=30
