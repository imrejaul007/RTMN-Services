{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --legacy-peer-deps",
    "runCommand": "node services/pilot-onboarding/src/index.js"
  },
  "deploy": {
    "numReplicas": 1,
    "healthCheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environments": {
    "production": {
      "healthCheckPath": "/health",
      "domain": "rtmn.io",
      "redirects": [
        { "from": "www.rtmn.io", "to": "rtmn.io" }
      ]
    },
    "staging": {
      "healthCheckPath": "/health",
      "domain": "staging.rtmn.io"
    }
  },
  "services": {
    "pilot-onboarding": {
      "source": "services/pilot-onboarding",
      "port": 4399,
      "healthCheck": "/health"
    }
  }
}
