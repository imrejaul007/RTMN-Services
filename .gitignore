!companies/Nexha/
!companies/Nexha/commerce-identity
!companies/Nexha/commerce-identity/**
# Re-ignore node_modules and other build artifacts inside the exception.
companies/Nexha/commerce-identity/node_modules/
companies/Nexha/commerce-identity/dist/

