# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
build/
.next/
out/

# Large binary files
*.apk
*.aab
*.ipa
*.dmg
*.exe
*.tar.gz
*.zip

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Environment
.env
.env.local

# Companies folder (each has its own repo)
companies/*
# NeXha commerce-identity exception: developed in-tree until the
# separate NeXha repo is set up.
!companies/Nexha/
!companies/Nexha/commerce-identity
!companies/Nexha/commerce-identity/**
# Re-ignore node_modules and other build artifacts inside the exception.
companies/Nexha/commerce-identity/node_modules/
companies/Nexha/commerce-identity/dist/

# RTMN subfolder (separate repo)
RTMN/
