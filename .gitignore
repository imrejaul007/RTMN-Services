companies/RTNM-Digital/**/.env.local
companies/RTNM-Group/**/node_modules/
companies/RTNM-Group/**/dist/
companies/RTNM-Group/**/.next/
companies/RTNM-Group/**/.env.local

# AdBazaar - separate repo
companies/AdBazaar/

