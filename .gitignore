# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
build/
.next/
out/

# Large binary files
*.apk
*.aab
*.ipa
*.dmg
*.exe
*.tar.gz
*.zip

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Environment
.env
.env.local

# =============================================
# COMPANIES FOLDER - Selective tracking
# =============================================
# IMPORTANT: Gitignore uses FIRST matching rule.
# Exceptions MUST come BEFORE the blanket ignore.
# DO NOT use glob patterns after negations.

# Exception: NeXha commerce-identity (developed in-tree)
!companies/Nexha/commerce-identity/
companies/Nexha/commerce-identity/node_modules/
companies/Nexha/commerce-identity/dist/

# Exception: RTNM-Group Services
!companies/RTNM-Group/boa-os/
!companies/RTNM-Group/boa-sutar-bridge/
companies/RTNM-Group/boa-os/node_modules/
companies/RTNM-Group/boa-os/dist/
companies/RTNM-Group/boa-sutar-bridge/node_modules/
companies/RTNM-Group/boa-sutar-bridge/dist/
!companies/RTNM-Group/boa-os/render.yaml
!companies/RTNM-Group/boa-sutar-bridge/render.yaml

# Exception: RABTUL-Technologies Services (moved to companies/* section above)
!companies/RABTUL-Technologies/REZ-SLA-monitor/render.yaml
!companies/RABTUL-Technologies/REZ-breach-detector/render.yaml
!companies/RABTUL-Technologies/REZ-economy-os/render.yaml
!companies/RABTUL-Technologies/REZ-trust-scorer/render.yaml

# Exception: REZ-Merchant Services (India Payment & Integration)
!companies/REZ-Merchant/industry-os/rez-payment-gateway-service/
!companies/REZ-Merchant/REZ-merchant-integration-service/
companies/REZ-Merchant/industry-os/rez-payment-gateway-service/node_modules/
companies/REZ-Merchant/industry-os/rez-payment-gateway-service/dist/
companies/REZ-Merchant/REZ-merchant-integration-service/node_modules/
companies/REZ-Merchant/REZ-merchant-integration-service/dist/

# Exception: HOJAI AI Multilingual (Arabic & European languages)
!companies/hojai-ai/hojai-multilingual/
companies/hojai-ai/hojai-multilingual/node_modules/
companies/hojai-ai/hojai-multilingual/dist/

# Exception: Do App (separate repo at github.com/imrejaul007/do-app)
# Lives at companies/do-app/ for convenience but has its own .git
# See https://github.com/imrejaul007/do-app for the canonical source
/companies/do-app/backend/node_modules/
/companies/do-app/backend/dist/
/companies/do-app/mobile/node_modules/
/companies/do-app/mobile/.expo/
/companies/do-app/mobile/.expo-shared/

# Default: Ignore ALL companies (each has its own repo)
companies/*
# ...but allow audit/audit-summary docs at the companies/ root
!/companies/REZ-Workspace-AUDIT-*.md
!/companies/AUDIT-FINAL-*.md
!/companies/AUDIT-LEGACY-DUPLICATES-*.md
!/companies/SESSION-SUMMARY-*.md
!/companies/REORGANIZATION-SUMMARY-*.md

# RABTUL-Technologies: re-include specific services (the rest is gitignored)
!/companies/RABTUL-Technologies/REZ-SLA-monitor/
!/companies/RABTUL-Technologies/REZ-breach-detector/
!/companies/RABTUL-Technologies/REZ-economy-os/
!/companies/RABTUL-Technologies/REZ-trust-scorer/
!/companies/RABTUL-Technologies/REZ-Revenue-AI/
!/companies/RABTUL-Technologies/rez-intelligence-integration/
/companies/RABTUL-Technologies/REZ-SLA-monitor/node_modules/
/companies/RABTUL-Technologies/REZ-SLA-monitor/dist/
/companies/RABTUL-Technologies/REZ-breach-detector/node_modules/
/companies/RABTUL-Technologies/REZ-breach-detector/dist/
/companies/RABTUL-Technologies/REZ-economy-os/node_modules/
/companies/RABTUL-Technologies/REZ-economy-os/dist/
/companies/RABTUL-Technologies/REZ-trust-scorer/node_modules/
/companies/RABTUL-Technologies/REZ-trust-scorer/dist/
/companies/RABTUL-Technologies/REZ-Revenue-AI/node_modules/
/companies/RABTUL-Technologies/REZ-Revenue-AI/dist/
/companies/RABTUL-Technologies/rez-intelligence-integration/node_modules/
/companies/RABTUL-Technologies/rez-intelligence-integration/dist/

# BUT: Do App (imrejaul007/do-app) gets re-included below because it lives in this folder for convenience
!/companies/do-app
!/companies/do-app/**

# HOJAI AI - in-tree brand/marketing layer (replaces the old hojai-ai submodule)
!companies/HOJAI-AI/
companies/HOJAI-AI/node_modules/
companies/HOJAI-AI/**/node_modules/
companies/HOJAI-AI/dist/
companies/HOJAI-AI/**/dist/

# NeXha services built in-tree (procurement-os, distribution-os, trade-finance,
# autonomous-logistics, capability-os, discovery-os, reputation-os, etc.).
# These are full TypeScript services with their own tests + Dockerfile.
# See ADR-0008. The blanket companies/* rule above needs explicit negations here.
!/companies/Nexha/services/procurement-os/
!/companies/Nexha/services/distribution-os/
!/companies/Nexha/services/trade-finance/
!/companies/Nexha/services/nexha-autonomous-logistics/
!/companies/Nexha/services/nexha-capability-os/
!/companies/Nexha/services/nexha-discovery-os/
!/companies/Nexha/services/nexha-reputation-os/
!/companies/Nexha/services/nexha-acp-messaging/
!/companies/Nexha/services/nexha-business-directory/
!/companies/Nexha/services/nexha-commerce-runtime/
!/companies/Nexha/services/nexha-gateway/
!/companies/Nexha/services/nexha-mission-planner/
!/companies/Nexha/services/nexha-partner-graph/
!/companies/Nexha/services/nexha-pricing-network/
!/companies/Nexha/services/nexha-provisioning-engine/
!/companies/Nexha/services/nexha-tenant-summary/
!/companies/Nexha/services/nexha-trade-finance-network/
!/companies/Nexha/services/nexha-warehouse-network/
!/companies/Nexha/services/nexha-distribution-network/
!/companies/Nexha/services/nexha-supplier-network/
!/companies/Nexha/services/nexha-hooks-sdk/
!/companies/Nexha/services/ecosystem-connector/
/companies/Nexha/services/*/node_modules/
/companies/Nexha/services/*/dist/

# HOJAI AI - recovered source from commit 08a6bf87e (historical snapshot)
!companies/HOJAI-AI-restored/
companies/HOJAI-AI-restored/node_modules/
companies/HOJAI-AI-restored/**/node_modules/
companies/HOJAI-AI-restored/dist/
companies/HOJAI-AI-restored/**/dist/

# Legacy-audit archives - track all legacy content from monorepo companies
!/companies/LawGens/
!/companies/LawGens/**
!/companies/Nexha/
!/companies/Nexha/**
!/companies/RTNM-Digital/
!/companies/RTNM-Digital/**
!/companies/RTNM-Group/
!/companies/RTNM-Group/**

# REZ-SalesMind is a standalone repo (has its own .git), not part of RTMN
companies/RTNM-Digital/REZ-SalesMind/

