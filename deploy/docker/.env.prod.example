# RTMN BrandPulse Production Environment Variables
# Copy this file to .env.prod and fill in your actual values
# NEVER commit .env.prod to version control

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment
NODE_ENV=production
PORT=4770

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# MongoDB Atlas Connection String
# Replace with your actual MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/brandpulse?retryWrites=true&w=majority

# Local MongoDB (for development only)
# MONGODB_URI=mongodb://admin:changeme@mongodb:27017/brandpulse?authSource=admin

# Redis Connection
# For cloud Redis (Redis Cloud, ElastiCache, etc.)
REDIS_URL=rediss://:password@redis.cloud:6379

# For local Redis
# REDIS_URL=redis://:changeme@redis:6379

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT Configuration
# Generate with: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-here-generate-with-openssl-rand-base64-64

# Session Configuration
# Generate with: openssl rand -base64 64
SESSION_SECRET=your-session-secret-here-generate-with-openssl-rand-base64-64

# CORS Origins (comma-separated in production)
CORS_ORIGIN=https://dashboard.rtmn.io,https://app.rtmn.io

# =============================================================================
# RTMN ECOSYSTEM INTEGRATION
# =============================================================================

# RTMN API Key for internal services
RTMN_API_KEY=rtmn_prod_your-api-key-here

# RTMN SDK Configuration
RTNM_SDK_URL=https://api.rtmn.io
RTNM_SDK_KEY=rtmn_prod_your-sdk-key-here

# =============================================================================
# RATE LIMITING
# =============================================================================

# Maximum requests per minute per IP
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# MONITORING & ERROR TRACKING
# =============================================================================

# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/your-org/projects/brandpulse/keys/
SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# PAYMENT PROCESSING (STRIPE)
# =============================================================================

# Stripe API Keys
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxx_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_xxxxx_your_webhook_secret

# Stripe webhook endpoint secret for local testing
STRIPE_WEBHOOK_LOCAL_SECRET=whsec_xxxxx

# =============================================================================
# AI / MACHINE LEARNING
# =============================================================================

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx_your_openai_api_key

# AI Model Configuration
AI_MODEL=gpt-4-turbo-preview
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7

# =============================================================================
# FRONTEND / DASHBOARD
# =============================================================================

# Dashboard API URL
NEXT_PUBLIC_API_URL=https://api.rtmn.io
NEXT_PUBLIC_WS_URL=wss://api.rtmn.io

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SEGMENT_KEY=xxxxx

# =============================================================================
# CLOUD STORAGE (S3 / GCS)
# =============================================================================

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=rtmn-brandpulse-uploads

# For backup scripts
S3_BUCKET_NAME=rtmn-backups
S3_BUCKET_REGION=us-east-1

# =============================================================================
# EMAIL (SENDGRID / SES)
# =============================================================================

# SendGrid
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=noreply@rtmn.io
SENDGRID_FROM_NAME=RTMN BrandPulse

# =============================================================================
# CDN & ASSET DELIVERY
# =============================================================================

# CloudFlare
CLOUDFLARE_API_TOKEN=your-cloudflare-token
CLOUDFLARE_ZONE_ID=your-zone-id

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features
FEATURE_AI_INSIGHTS=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_REAL_TIME_COLLABORATION=true
FEATURE_EXPORT_PDF=true
FEATURE_INTEGRATION_SLACK=true
FEATURE_INTEGRATION_ZAPIER=true

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# Worker threads
WORKER_THREADS=4

# Connection pool
DB_CONNECTION_POOL_SIZE=20
DB_IDLE_TIMEOUT_MS=30000

# Cache TTL (seconds)
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=3600
CACHE_TTL_LONG=86400

# =============================================================================
# DATABASE POLLING & SYNC
# =============================================================================

# WebSocket configuration
WS_PING_INTERVAL=30000
WS_PING_TIMEOUT=10000

# =============================================================================
# SECURITY HEADERS
# =============================================================================

# HSTS (HTTP Strict Transport Security)
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# Content Security Policy
CSP_REPORT_URI=https://rtmn.io/csp-violations

# =============================================================================
# BUSINESS SETTINGS
# =============================================================================

# Company Information
COMPANY_NAME=RTMN
COMPANY_URL=https://rtmn.io
SUPPORT_EMAIL=support@rtmn.io

# Default timezone
DEFAULT_TIMEZONE=Asia/Kolkata

# =============================================================================
# DEBUG (Disable in production!)
# =============================================================================

DEBUG=false
VERBOSE_LOGGING=false
