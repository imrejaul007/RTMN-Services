{
  "name": "rtmn-services",
  "version": "1.0.0",
  "description": "RTMN - Real-Time Multi-industry Network Services - 24 Industry Operating Systems",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@hojai/governance",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "clean": "rm -rf packages/*/dist packages/*/node_modules"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "express": "^5.2.1",
    "express-async-errors": "^3.1.1"
  }
}
