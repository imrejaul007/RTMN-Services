# =============================================================================
# Nexha Portal — Environment Variables Template (Next.js)
# =============================================================================
# In Next.js, only env vars prefixed with NEXT_PUBLIC_ are exposed to the
# browser. Server-side secrets (if any are added later) must NOT have this prefix.
#
# Copy this file to `.env.local` for local development, or set the variables
# in your Vercel project settings for production deployments.
# =============================================================================

# Backend API URL (no trailing slash, include protocol).
# Dev:    http://localhost:8000
# Prod:   https://nexha-commerce-identity.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# Local development:
#   cp .env.example .env.local
#   npm run dev
#
# Production (Vercel):
#   vercel env add NEXT_PUBLIC_API_URL production
#   # paste: https://nexha-commerce-identity.onrender.com
#   vercel --prod
#
# .env.local is in .gitignore and will never be committed.
# =============================================================================
