# AdBazaar Pixel Configuration
# Universal tracking pixel - Web, Server, Mobile

# Server
PORT=4962
NODE_ENV=development
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/adbazaar-pixel

# Internal Service
INTERNAL_SERVICE_TOKEN=your-internal-token

# CDP Service
CDP_SERVICE_URL=http://localhost:4901

# Pixel API URL (for SDK)
PIXEL_API_URL=http://localhost:4962

# Test Mode
TEST_EVENT_CODE=TEST

# Meta Conversions API
META_PIXEL_ID=your-meta-pixel-id
META_ACCESS_TOKEN=your-meta-access-token
META_CONVERSIONS_API_URL=https://graph.facebook.com/v18.0

# Google Enhanced Conversions
GOOGLE_CONVERSION_ID=your-google-conversion-id
GOOGLE_CONVERSION_TOKEN=your-google-token
GOOGLE_CONVERSIONS_URL=https://googleads.googleapis.com

# TikTok Events API
TIKTOK_PIXEL_ID=your-tiktok-pixel-id
TIKTOK_ACCESS_TOKEN=your-tiktok-token
TIKTOK_EVENTS_URL=https://business-api.tiktok.com
