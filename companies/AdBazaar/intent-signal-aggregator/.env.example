# Intent Signal Aggregator Configuration
# Copy to .env and configure

# Server
PORT=4800
NODE_ENV=development
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/intent-signals

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:3000,https://rez.money

# Internal Service Authentication
# JSON format: {"service-name": "token"}
INTERNAL_SERVICE_TOKENS_JSON={"intent-signal-aggregator":"your-token-here","hojai-ai-gateway":"your-token-here"}
# Or legacy single token:
# INTERNAL_SERVICE_TOKEN=your-legacy-token-here
