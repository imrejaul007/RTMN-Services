{
  "name": "rtnm-company-credit",
  "version": "1.0.0",
  "description": "Company Credit service for RTNM Economic Network - Manages credit limits, BNPL, and payment terms",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "docker:build": "docker build -t rtnm-company-credit .",
    "docker:run": "docker run -p 6006:6006 rtnm-company-credit"
  },
  "keywords": [
    "rtnm",
    "company-credit",
    "bnpl",
    "credit-limit",
    "payment-terms"
  ],
  "author": "RTNM Group",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "mongoose": "^8.2.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}