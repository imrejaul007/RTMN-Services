{
  "name": "rtnm-company-twins",
  "version": "1.0.0",
  "description": "Company Twins service for RTNM Economic Network - Every RTNM company has a twin with budget, policies, AI agent, and trust rules",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "docker:build": "docker build -t rtnm-company-twins .",
    "docker:run": "docker run -p 6002:6002 rtnm-company-twins"
  },
  "keywords": [
    "rtnm",
    "company-twins",
    "enterprise",
    "digital-twin",
    "budget",
    "policies",
    "ai-agent"
  ],
  "author": "RTNM Group",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.2.0",
    "winston": "^3.11.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.2.0",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "@types/jest": "^29.5.12",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
