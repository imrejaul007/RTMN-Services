{
  "name": "rtnm-inter-company-graph",
  "version": "1.0.0",
  "description": "Inter-Company Graph service for RTNM Economic Network",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rm -rf dist coverage",
    "docker:build": "docker build -t rtnm-inter-company-graph .",
    "docker:run": "docker run -d -p 6001:6001 rtnm-inter-company-graph",
    "docker:stop": "docker stop rtnm-inter-company-graph"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "mongoose": "^8.2.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.20",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "rtnm",
    "inter-company",
    "graph",
    "economic-network",
    "company-relationships"
  ],
  "author": "RTNM Group",
  "license": "MIT"
}