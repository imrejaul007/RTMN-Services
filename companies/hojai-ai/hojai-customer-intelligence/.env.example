# Customer Intelligence Service (CDP) Configuration
# Port for the service to run on
PORT=4885

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/hojai-cdp

# Service Configuration
SERVICE_NAME=hojai-customer-intelligence
NODE_ENV=development

# API Configuration
API_VERSION=v1
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Risk Scoring Configuration
RISK_HIGH_THRESHOLD=70
RISK_MEDIUM_THRESHOLD=40
RISK_LOW_THRESHOLD=20

# Identity Resolution Configuration
IDENTITY_MATCH_CONFIDENCE_THRESHOLD=0.85

# JWT Configuration (for service-to-service auth)
JWT_SECRET=your-secret-key-change-in-production

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://rtmn-pilot-portal.vercel.app

# Logging
LOG_LEVEL=info
