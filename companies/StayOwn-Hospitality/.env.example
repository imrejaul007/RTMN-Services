# ===========================================
# STAYOWN-HOSPITALITY - Environment Variables
# ===========================================
# Copy to .env.local and fill in values
# ===========================================

# ===========================================
# DEVELOPMENT URLS (Local Development)
# ===========================================

DEV_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hotel_ota
DEV_API_URL=http://localhost:3000
DEV_OTA_WEB_URL=http://localhost:3003
DEV_HOTEL_PANEL_URL=http://localhost:3001
DEV_ADMIN_PANEL_URL=http://localhost:3002
DEV_CORPORATE_PANEL_URL=http://localhost:3004

# REZ Services (Dev)
DEV_REZ_AUTH_URL=http://localhost:4002
DEV_REZ_WALLET_URL=http://localhost:4004
DEV_REZ_PAYMENT_URL=http://localhost:4006
DEV_REZ_MERCHANT_URL=http://localhost:4800
DEV_REZ_CONSUMER_URL=http://localhost:3000

# RTMN Foundation Services (Dev)
DEV_CORPID_URL=http://localhost:4702
DEV_MEMORY_OS_URL=http://localhost:4703
DEV_GENIE_URL=http://localhost:4701
DEV_TWIN_OS_HUB_URL=http://localhost:4705
DEV_GOAL_OS_URL=http://localhost:4242

# Event Bus (Dev)
DEV_EVENT_BUS_URL=http://localhost:4510
DEV_SERVICE_REGISTRY_URL=http://localhost:4399

# Hotel OS (Dev)
DEV_HOTEL_OS_URL=http://localhost:5025

# ===========================================
# PRODUCTION URLS (Render Deployment)
# ===========================================

# Database (Production - Neon/Supabase/Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/hotel_ota_prod

# StayOwn Apps (Production)
API_URL=https://hotel-ota-api.onrender.com
OTA_WEB_URL=https://hotel-ota-web.onrender.com
HOTEL_PANEL_URL=https://hotel-ota-hotel-panel.onrender.com
ADMIN_PANEL_URL=https://hotel-ota-admin.onrender.com
CORPORATE_PANEL_URL=https://hotel-ota-corporate.onrender.com

# REZ Services (Production)
REZ_AUTH_URL=https://rez-auth.onrender.com
REZ_WALLET_URL=https://rez-wallet.onrender.com
REZ_PAYMENT_URL=https://rez-payment.onrender.com
REZ_MERCHANT_URL=https://rez-merchant.onrender.com
REZ_CONSUMER_URL=https://rez-consumer.onrender.com

# RTMN Foundation Services (Production)
CORPID_URL=https://corpid-service.onrender.com
MEMORY_OS_URL=https://memory-os.onrender.com
GENIE_URL=https://hojai-genie.onrender.com
TWIN_OS_HUB_URL=https://twinos-hub.onrender.com
GOAL_OS_URL=https://goal-os.onrender.com

# Event Bus (Production)
EVENT_BUS_URL=https://rez-event-bus.onrender.com
SERVICE_REGISTRY_URL=https://rez-ecosystem-connector.onrender.com

# Hotel OS (Production)
HOTEL_OS_URL=https://hotel-os.onrender.com

# ===========================================
# EXTERNAL SERVICES (Production)
# ===========================================

# Hotel Search API
MAKCORPS_API_KEY=your-makcorps-api-key
MAKCORPS_API_URL=https://api.makcorps.com

# SMS OTP (MSG91)
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER=STAYOWN

# Payment Gateway
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@stayown.com

# AWS S3 for file uploads
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=stayown-uploads
AWS_S3_REGION=ap-south-1

# ===========================================
# REZ MIND AI SERVICES (Production)
# ===========================================
REZ_SUPPORT_COPILOT_URL=https://rez-support-copilot.onrender.com
REZ_EVENT_PLATFORM_URL=https://rez-event-platform.onrender.com
REZ_USER_INTELLIGENCE_URL=https://rez-user-intelligence.onrender.com
REZ_KNOWLEDGE_BASE_URL=https://rez-knowledge-base.onrender.com
REZ_INTENT_GRAPH_URL=https://rez-intent-graph.onrender.com

# ===========================================
# SOCKET.IO (Production)
# ===========================================
SOCKET_URL=wss://socket.stayown.com

# ===========================================
# PUSH NOTIFICATIONS
# ===========================================
FCM_SERVER_KEY=your-fcm-server-key

# ===========================================
# API KEYS
# ===========================================
HOTEL_API_KEY=your-hotel-api-key
STAYOWN_API_KEY=your-stayown-api-key
INTERNAL_SERVICE_TOKEN=your-internal-service-token

# ===========================================
# SECURITY
# ===========================================
JWT_SECRET=your-production-jwt-secret-min-32-chars
ENCRYPTION_KEY=your-32-char-encryption-key

# ===========================================
# REDIS (Production)
# ===========================================
REDIS_URL=redis://redis-host:6379
REDIS_PASSWORD=your-redis-password

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_QR_ROOM_SERVICE=true
ENABLE_AI_CONCIERGE=true
ENABLE_LOYALTY=true
ENABLE_CHANNEL_MANAGER=true
ENABLE_VOICE_AI=false
ENABLE_DIGITAL_KEY=false
