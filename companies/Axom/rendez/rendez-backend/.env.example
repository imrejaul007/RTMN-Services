# Rendez Backend — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

NODE_ENV=development
PORT=4020

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://rendez:changeme@localhost:5432/rendez_dev
TEST_DATABASE_URL=postgresql://rendez:changeme@localhost:5432/rendez_test

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_64_chars_min
JWT_EXPIRES_IN=7d

# REZ Mind Intent Capture
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com
REZ_MIND_URL=https://rez-event-platform.onrender.com

# REZ Partner API
REZ_PARTNER_API_URL=https://rez-backend.onrender.com
REZ_PARTNER_API_KEY=your_rez_partner_api_key_here
REZ_WEBHOOK_SECRET=your_rez_webhook_secret_here

# REZ OAuth2 (Partner SSO)
REZ_AUTH_SERVICE_URL=https://rez-auth-service.onrender.com
REZ_OAUTH_CLIENT_ID=rendez-app
# Generate with: openssl rand -base64 64
REZ_OAUTH_CLIENT_SECRET=generate_with_openssl_rand_hex_32
# Redirect URI — must match PARTNER_RENDEZ_REDIRECT_URI in REZ Auth Service
# Dev: http://localhost:4000/api/auth/oauth/callback
# Prod: https://your-rendez-domain.com/api/auth/oauth/callback
# NOTE: /api/auth/oauth/callback (the oauth router is mounted at /api/auth/oauth in index.ts)
REZ_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/oauth/callback

# REZ Backend (outbound webhooks)
REZ_BACKEND_URL=https://rez-backend.onrender.com
RENDEZ_WEBHOOK_SECRET=your_rendez_webhook_secret_here

# Firebase / FCM — Option A: file path
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Option B: inline JSON (for Render/Railway)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIREBASE_PROJECT_ID=your_firebase_project_id

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Admin API
ADMIN_API_KEY=change_me_to_a_secure_admin_key

# Fraud / Tuning
MAX_GIFTS_PER_DAY=5
GIFT_EXPIRY_HOURS=48
MATCH_EXPIRY_HOURS=72
REWARD_COOLDOWN_DAYS=90
GIFT_CATALOG_CACHE_TTL_SECONDS=21600

# Sentry (optional — leave blank to disable)
SENTRY_DSN=
