{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    // RD-CRIT-01 FIX: Explicitly opt out of automatic @types/* inclusion.
    // Without this, TypeScript auto-discovers all @types/* packages and fails with
    // "Cannot find type definition file for react-native" when a transitive dep
    // indirectly references @types/react-native. This is a known TS 5.x issue.
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/tests"]
}
