# Rendez Admin — Environment Variables
# Copy to .env.local and fill in values. NEVER commit .env.local.

# Backend API URL
NEXT_PUBLIC_API_URL=https://rendez-backend.onrender.com

# Server-side JWT signing secret (must match ADMIN_JWT_SECRET in backend)
# Generate: openssl rand -hex 32
ADMIN_JWT_SECRET=generate_with_openssl_rand_hex_32
