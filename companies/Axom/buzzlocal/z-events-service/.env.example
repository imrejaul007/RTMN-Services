# Z-Events Service Environment Variables

PORT=4008
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/z-events

# Internal Token
INTERNAL_SERVICE_TOKEN=your-internal-token

# Connected Services
CORPID_URL=http://localhost:4300
REZ_AUTH_URL=http://localhost:4002
REZ_WALLET_URL=http://localhost:4004
REZ_LOYALTY_URL=http://localhost:4040
GENIE_GATEWAY_URL=http://localhost:4701
ADBAZAAR_URL=http://localhost:5000
CORPPERKS_URL=http://localhost:4100

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
