# BuzzLocal Services Environment Variables

# Service URLs
BUZZLOCAL_FEED_URL=http://localhost:4200
BUZZLOCAL_SOCIETY_URL=http://localhost:4210
BUZZLOCAL_SAFETY_URL=http://localhost:4220
BUZZLOCAL_BUSINESS_URL=http://localhost:4230
BUZZLOCAL_CROWD_URL=http://localhost:4240
BUZZLOCAL_WEATHER_URL=http://localhost:4250

# MongoDB
MONGODB_URI=mongodb://localhost:27017/buzzlocal

# Internal Token
INTERNAL_SERVICE_TOKEN=your-internal-token

# Connected Services
CORPID_URL=http://localhost:4300
REZ_AUTH_URL=http://localhost:4002
GENIE_GATEWAY_URL=http://localhost:4701

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
