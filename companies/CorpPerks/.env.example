# CorpPerks Environment Variables
# Copy to .env and fill in values

# Server
NODE_ENV=development
PORT=4006

# Database
MONGODB_URI=mongodb://localhost:27017/corpperks
DATABASE_URL=postgresql://postgres:password@localhost:5432/corpperks

# Auth
JWT_SECRET=CHANGE_ME_generate_strong_secret_here

# CORS
CORS_ORIGINS=http://localhost:3000,https://corpperks.app

# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# HRIS Integrations
BAMBOOHR_API_KEY=
GREYTHR_API_KEY=
ZOHO_HR_API_KEY=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# RABTUL Services
RABTUL_AUTH_URL=https://rez-auth.onrender.com
RABTUL_WALLET_URL=https://rez-wallet.onrender.com