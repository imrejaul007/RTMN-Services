# REZ SalesMind Environment Variables

# Server
PORT=4760
NODE_ENV=development

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4760

# Logging
LOG_LEVEL=info

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# HubSpot CRM
HUBSPOT_API_KEY=your-hubspot-api-key
HUBSPOT_OWNER_ID=your-owner-id

# JWT (for auth if needed)
JWT_SECRET=your-jwt-secret
