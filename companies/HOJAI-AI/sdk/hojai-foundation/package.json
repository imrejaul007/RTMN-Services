{
  "name": "@hojai/foundation",
  "version": "1.0.0",
  "description": "HOJAI Foundation SDK — unified client for CorpID, MemoryOS, TwinOS, SADA Trust, Flow Orchestrator, and PolicyOS. Routes through the RTMN Hub (http://localhost:4399).",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./corp-id": {
      "types": "./dist/corp-id.d.ts",
      "import": "./dist/corp-id.js",
      "require": "./dist/corp-id.cjs",
      "default": "./dist/corp-id.js"
    },
    "./memory": {
      "types": "./dist/memory.d.ts",
      "import": "./dist/memory.js",
      "require": "./dist/memory.cjs",
      "default": "./dist/memory.js"
    },
    "./twin": {
      "types": "./dist/twin.d.ts",
      "import": "./dist/twin.js",
      "require": "./dist/twin.cjs",
      "default": "./dist/twin.js"
    },
    "./trust": {
      "types": "./dist/trust.d.ts",
      "import": "./dist/trust.js",
      "require": "./dist/trust.cjs",
      "default": "./dist/trust.js"
    },
    "./flow": {
      "types": "./dist/flow.d.ts",
      "import": "./dist/flow.js",
      "require": "./dist/flow.cjs",
      "default": "./dist/flow.js"
    },
    "./policy": {
      "types": "./dist/policy.d.ts",
      "import": "./dist/policy.js",
      "require": "./dist/policy.cjs",
      "default": "./dist/policy.js"
    }
  },
  "scripts": {
    "build": "npm run types && npm run bundle",
    "types": "tsc -p tsconfig.json --emitDeclarationOnly --outDir dist",
    "bundle": "node scripts/build.mjs",
    "dev": "npm run bundle && npm run types -- --watch",
    "test": "npm run build && node --test dist/__tests__/index.test.js",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "hojai",
    "sdk",
    "corp-id",
    "memory",
    "twin",
    "trust",
    "policy",
    "flow",
    "ai",
    "sutar",
    "nexha"
  ],
  "author": "HOJAI AI",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.3.3"
  }
}
