{
  "name": "@hojai/razor",
  "version": "2.1.0",
  "description": "Razor SDK v2 - Client for the HOJAI RAZO Keyboard Communication OS v2.1. 84+ endpoints covering Magic Wand, Emotion Detection, Voice, i18n, Family, Pay, Life, Founder Mode, Negotiation, Photo Intelligence, and MemoryOS/TwinOS integration.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./v2": {
      "import": "./dist/v2.mjs",
      "require": "./dist/v2.js",
      "default": "./dist/v2.js"
    },
    "./hooks": {
      "import": "./hooks/index.ts",
      "require": "./hooks/index.ts",
      "default": "./hooks/index.ts"
    },
    "./components": {
      "import": "./components/index.ts",
      "require": "./components/index.ts",
      "default": "./components/index.ts"
    },
    "./intents": {
      "import": "./dist/intents.mjs",
      "require": "./dist/intents.js",
      "default": "./dist/intents.js"
    },
    "./messages": {
      "import": "./dist/messages.mjs",
      "require": "./dist/messages.js",
      "default": "./dist/messages.js"
    },
    "./channels": {
      "import": "./dist/channels.mjs",
      "require": "./dist/channels.js",
      "default": "./dist/channels.js"
    },
    "./sessions": {
      "import": "./dist/sessions.mjs",
      "require": "./dist/sessions.js",
      "default": "./dist/sessions.js"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node --test dist/__tests__/*.test.js"
  },
  "keywords": [
    "hojai",
    "razor",
    "razo",
    "keyboard",
    "intent",
    "messaging",
    "communication",
    "sdk",
    "magic-wand",
    "emotion-detection",
    "voice",
    "negotiation",
    "photo-intelligence",
    "memory"
  ],
  "author": "HOJAI AI",
  "license": "MIT",
  "engines": { "node": ">=18" },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
