{
  "name": "@hojai/widget-react",
  "version": "1.0.0",
  "description": "React wrapper for the HOJAI Widget.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:cjs": "tsc -p tsconfig.cjs.json && mv dist/index.js dist/index.cjs && mv dist/index.d.ts dist/index.d.cts",
    "build:esm": "tsc -p tsconfig.esm.json && mv dist/index.js dist/index.mjs",
    "build:lib": "npm run build:cjs && npm run build:esm",
    "build:test": "tsc -p tsconfig.test.json",
    "build": "npm run build:lib && npm run build:test",
    "test": "npm run build:test && node --test dist-test/__tests__/*.test.js"
  },
  "keywords": [
    "hojai",
    "widget",
    "react",
    "ai",
    "chat",
    "sutar",
    "agent"
  ],
  "author": "HOJAI AI",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@hojai/widget-core": "file:../hojai-widget-core",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3"
  }
}
