{
  "name": "@hojai/memory-sdk",
  "version": "1.0.0",
  "description": "Unified SDK for HOJAI MemoryOS - Access all 26 memory services through a single interface",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "dev": "tsc --watch",
    "lint": "eslint src/"
  },
  "keywords": ["memory", "ai", "sdk", "hojai", "enterprise"],
  "author": "HOJAI AI",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
