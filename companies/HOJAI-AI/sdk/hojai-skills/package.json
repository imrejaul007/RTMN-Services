{
  "name": "@hojai/skills",
  "version": "1.0.0",
  "description": "Skills SDK - Client for HOJAI SkillOS + Skill Marketplace + Prompt Manager + Workflow Marketplace + Translation OS.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.mjs", "require": "./dist/index.js", "default": "./dist/index.js" },
    "./os": { "import": "./dist/os.mjs", "require": "./dist/os.js", "default": "./dist/os.js" },
    "./marketplace": { "import": "./dist/marketplace.mjs", "require": "./dist/marketplace.js", "default": "./dist/marketplace.js" },
    "./prompts": { "import": "./dist/prompts.mjs", "require": "./dist/prompts.js", "default": "./dist/prompts.js" },
    "./workflows": { "import": "./dist/workflows.mjs", "require": "./dist/workflows.js", "default": "./dist/workflows.js" },
    "./translation": { "import": "./dist/translation.mjs", "require": "./dist/translation.js", "default": "./dist/translation.js" },
    "./types": { "import": "./dist/types.mjs", "require": "./dist/types.js", "default": "./dist/types.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc src/__tests__/index.test.ts --target ES2022 --module ES2022 --moduleResolution node --esModuleInterop --skipLibCheck --declaration --outDir dist",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node --test dist/__tests__/*.test.js"
  },
  "keywords": ["hojai", "skills", "skill-os", "prompts", "workflows", "translation", "sdk"],
  "author": "HOJAI AI", "license": "MIT",
  "engines": { "node": ">=18" },
  "devDependencies": { "typescript": "^5.3.3", "@types/node": "^20.10.0" }
}
