{
  "name": "@hojai/core-sdk",
  "version": "1.0.0",
  "description": "Unified TypeScript SDK for HOJAI AI — all 15 platform services in one SDK",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest --reporter=verbose",
    "prepublish": "npm run build"
  },
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
