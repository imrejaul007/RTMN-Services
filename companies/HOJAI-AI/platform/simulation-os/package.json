{
  "name": "@hojai/simulation-os",
  "version": "2.0.0",
  "description": "SimulationOS 2.0 - Production-ready simulation engine for SUTAR",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "simulation",
    "monte-carlo",
    "what-if-analysis",
    "risk-analysis",
    "business-simulation",
    "sutar"
  ],
  "author": "HOJAI AI",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1",
    "simple-statistics": "^7.8.3",
    "ml-regression": "^5.0.0",
    "ml-matrix": "^6.11.0",
    "date-fns": "^3.6.0",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "dotenv": "^16.4.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.11.16",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2",
    "tsx": "^4.7.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}