{
  "name": "@hojai/policy-os",
  "version": "1.3.1",
  "description": "PolicyOS — Universal governance, trust, authorization, compliance, and decision policy platform",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test __tests__/unit/events.test.mjs __tests__/unit/auth.test.mjs && bash tests/smoke.sh && bash tests/e2e.sh",
    "test:events": "node --test __tests__/unit/events.test.mjs",
    "test:auth": "node --test __tests__/unit/auth.test.mjs",
    "test:expression": "bash tests/expression.test.sh",
    "test:persistence": "bash tests/persistence.test.sh",
    "test:all": "node --test __tests__/**/*.test.mjs && bash tests/*.sh",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"__tests__/**/*.mjs\" \"tests/*.sh\"",
    "check": "node --check src/index.js && node --check src/expression-evaluator.js && node --check src/lib/*.js && node --check src/middleware/*.js && node --check src/routes/*.js && node --check src/services/*.js"
  },
  "dependencies": {
    "@rtmn/shared": "file:../../../shared",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  }
}
