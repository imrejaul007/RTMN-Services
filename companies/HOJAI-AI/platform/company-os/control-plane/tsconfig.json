{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "paths": {
      "@hojai/company-os-composition-engine": ["../composition-engine/src"],
      "@hojai/company-os-manifest-registry": ["../manifest-registry/src"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "../composition-engine/src/**/*", "../manifest-registry/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
