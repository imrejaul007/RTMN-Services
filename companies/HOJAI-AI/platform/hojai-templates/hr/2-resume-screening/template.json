{
  "id": "hr-resume-screening",
  "name": "AI Resume Screening",
  "category": "hr",
  "description": "Automatically screen resumes, score candidates, and rank for hiring",
  "version": "1.0.0",
  "triggers": [{"type": "email", "source": "inbox", "filter": "resume|application|cv"}],
  "nodes": [
    {"id": "1", "type": "email", "name": "Receive Resume", "config": {"source": "inbox", "filter": "resume_attachment"}},
    {"id": "2", "type": "ocr", "name": "Extract Data", "config": {"fields": ["name", "email", "phone", "experience", "skills", "education"]}},
    {"id": "3", "type": "ai_agent", "name": "Score Resume", "config": {"agent": "hr_agent", "prompt": "Score resume against job requirements. Rate: skills match, experience relevance, education fit, culture fit."}},
    {"id": "4", "type": "condition", "name": "Pass Threshold?", "config": {"field": "score.total", "operator": ">=", "value": 70}},
    {"id": "5a", "type": "hris", "name": "Create Candidate", "config": {"action": "create_candidate"}},
    {"id": "5b", "type": "email", "name": "Send Rejection", "config": {"template": "application_rejected"}},
    {"id": "6", "type": "schedule", "name": "Schedule Review", "config": {"delay_hours": 24, "task": "review_candidates"}},
    {"id": "7", "type": "slack", "name": "Notify HR", "config": {"channel": "hr-team", "template": "new_candidates"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5a", "condition": "score >= 70"},
    {"from": "4", "to": "5b", "condition": "score < 70"},
    {"from": "5a", "to": "6"},
    {"from": "6", "to": "7"}
  ],
  "agents": ["hr_agent"],
  "integrations": ["email", "ocr", "hris", "slack"],
  "estimated_setup_time": "30 minutes",
  "price": {"subscription": 1499, "currency": "INR", "period": "month"},
  "tags": ["hr", "recruitment", "automation", "screening"]
}
