{
  "id": "hr-learning-recommendations",
  "name": "Learning Recommendations",
  "category": "hr",
  "description": "AI-powered skill gap analysis and learning recommendations",
  "version": "1.0.0",
  "triggers": [{"type": "schedule", "cron": "0 10 1 * *"}],
  "nodes": [
    {"id": "1", "type": "hris", "name": "Get Employee Data", "config": {"action": "get_employees_with_gaps"}},
    {"id": "2", "type": "ai_agent", "name": "Identify Gaps", "config": {"agent": "lnd_agent", "prompt": "Analyze: current skills, role requirements, career goals."}},
    {"id": "3", "type": "ai_agent", "name": "Recommend Courses", "config": {"agent": "lnd_agent", "prompt": "Recommend courses based on gaps and learning style."}},
    {"id": "4", "type": "email", "name": "Send Recommendations", "config": {"template": "learning_recommendations", "to": "{{employee.email}}"}},
    {"id": "5", "type": "crm", "name": "Update Learning Plan", "config": {"action": "update_learning_plan"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5"}
  ],
  "agents": ["lnd_agent"],
  "integrations": ["hris", "lms", "email"],
  "estimated_setup_time": "2 hours",
  "price": {"subscription": 999, "currency": "INR", "period": "month"},
  "tags": ["hr", "learning", "automation", "skills"]
}
