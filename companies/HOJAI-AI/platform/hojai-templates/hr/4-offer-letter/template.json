{
  "id": "hr-offer-letter-generator",
  "name": "Offer Letter Generator",
  "category": "hr",
  "description": "Generate personalized offer letters from templates with candidate-specific details",
  "version": "1.0.0",
  "triggers": [{"type": "event", "source": "hris", "event": "candidate.selected"}],
  "nodes": [
    {"id": "1", "type": "trigger", "name": "Candidate Selected", "config": {"source": "hris"}},
    {"id": "2", "type": "hris", "name": "Get Candidate Data", "config": {"action": "get_candidate", "fields": ["name", "position", "salary", "start_date", "benefits"]}},
    {"id": "3", "type": "ai_agent", "name": "Generate Letter", "config": {"agent": "hr_agent", "prompt": "Generate offer letter from template with candidate-specific details."}},
    {"id": "4", "type": "approval", "name": "Manager Approval", "config": {"approvers": ["reporting_manager"], "timeout": 24}},
    {"id": "5", "type": "document", "name": "Create PDF", "config": {"format": "pdf", "template": "offer_letter"}},
    {"id": "6", "type": "email", "name": "Send Offer", "config": {"template": "offer_letter", "attach_pdf": true}},
    {"id": "7", "type": "hris", "name": "Track Status", "config": {"action": "update_candidate", "field": "offer_sent", "date": "{{date}}"}},
    {"id": "8", "type": "memory", "name": "Log Activity", "config": {"action": "save", "memory_type": "offer_tracking"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5", "condition": "approved"},
    {"from": "5", "to": "6"},
    {"from": "6", "to": "7"},
    {"from": "7", "to": "8"}
  ],
  "agents": ["hr_agent"],
  "integrations": ["hris", "document", "email"],
  "estimated_setup_time": "30 minutes",
  "price": {"subscription": 999, "currency": "INR", "period": "month"},
  "tags": ["hr", "recruitment", "document", "automation"]
}
