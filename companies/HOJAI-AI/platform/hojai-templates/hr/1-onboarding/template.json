{
  "id": "hr-employee-onboarding",
  "name": "AI Employee Onboarding",
  "category": "hr",
  "description": "Automated employee onboarding with task tracking and team introductions",
  "version": "1.0.0",
  "triggers": [{"type": "event", "source": "hris", "event": "employee.added"}],
  "nodes": [
    {"id": "1", "type": "trigger", "name": "New Employee", "config": {"source": "hris"}},
    {"id": "2", "type": "ai_agent", "name": "Generate Plan", "config": {"agent": "hr_agent", "prompt": "Generate personalized onboarding plan based on role, department, experience level."}},
    {"id": "3", "type": "action", "name": "Create Tasks", "config": {"action": "create_checklist", "template": "onboarding"}},
    {"id": "4", "type": "email", "name": "Welcome Email", "config": {"to": "{{employee.email}}", "template": "welcome"}},
    {"id": "5", "type": "slack", "name": "Introduce to Team", "config": {"channel": "{{team.slack_channel}}"}},
    {"id": "6", "type": "calendar", "name": "Schedule Meetups", "config": {"events": ["team_lunch", "manager_1on1", "it_setup"]}},
    {"id": "7", "type": "action", "name": "Create Accounts", "config": {"systems": ["email", "slack", "github", "crm", "tools"]}},
    {"id": "8", "type": "schedule", "name": "Day 3 Check-in", "config": {"delay_days": 3, "task": "check_in"}},
    {"id": "9", "type": "schedule", "name": "Week 1 Review", "config": {"delay_days": 7, "task": "week1_review"}},
    {"id": "10", "type": "twin", "name": "Create Employee Twin", "config": {"twin": "employee_twin", "action": "create", "data": "{{employee}}"} },
    {"id": "11", "type": "hris", "name": "Update HRIS", "config": {"action": "update_status", "status": "onboarding_started"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "3", "to": "5"},
    {"from": "3", "to": "6"},
    {"from": "3", "to": "7"},
    {"from": "7", "to": "8"},
    {"from": "8", "to": "9"},
    {"from": "3", "to": "10"},
    {"from": "10", "to": "11"}
  ],
  "agents": ["hr_agent"],
  "integrations": ["hris", "email", "slack", "calendar", "twin"],
  "estimated_setup_time": "30 minutes",
  "price": {"subscription": 1499, "currency": "INR", "period": "month"},
  "tags": ["hr", "automation", "onboarding", "employee-experience"]
}
