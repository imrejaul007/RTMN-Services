{
  "id": "realestate-lead-capture",
  "name": "Real Estate Lead Capture",
  "category": "real-estate",
  "description": "Capture and qualify real estate leads from multiple channels",
  "version": "1.0.0",
  "triggers": [
    {"type": "webhook", "source": "website", "event": "form_submitted"},
    {"type": "whatsapp", "source": "wa_business", "event": "inquiry_received"}
  ],
  "nodes": [
    {"id": "1", "type": "trigger", "name": "Lead Received", "config": {"source": ["website", "whatsapp"]}},
    {"id": "2", "type": "ai_agent", "name": "Enrich Lead", "config": {"agent": "research_agent", "prompt": "Enrich lead with property preferences, budget, location, and timeline."}},
    {"id": "3", "type": "ai_agent", "name": "Score Lead", "config": {"agent": "analyst_agent", "prompt": "Score lead based on: budget, timeline, serious intent."}},
    {"id": "4", "type": "crm", "name": "Create Lead", "config": {"action": "create_lead", "source": "{{source}}"}},
    {"id": "5", "type": "condition", "name": "Hot Lead?", "config": {"field": "lead.score", "operator": ">=", "value": 80}},
    {"id": "6a", "type": "slack", "name": "Instant Alert", "config": {"channel": "sales-team", "template": "hot_lead"}},
    {"id": "6b", "type": "email", "name": "Auto Response", "config": {"template": "lead_received"}},
    {"id": "7", "type": "memory", "name": "Track Journey", "config": {"action": "save", "memory_type": "lead_journey"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5"},
    {"from": "5", "to": "6a", "condition": "score >= 80"},
    {"from": "5", "to": "6b", "condition": "score < 80"},
    {"from": "6a", "to": "7"},
    {"from": "6b", "to": "7"}
  ],
  "agents": ["research_agent", "analyst_agent"],
  "integrations": ["website", "whatsapp", "crm", "slack"],
  "estimated_setup_time": "2 hours",
  "price": {"subscription": 2999, "currency": "INR", "period": "month"},
  "tags": ["real-estate", "lead-capture", "automation"]
}
