{
  "id": "healthcare-insurance-verification",
  "name": "Insurance Verification",
  "category": "healthcare",
  "description": "Automated insurance eligibility verification before appointments",
  "version": "1.0.0",
  "triggers": [{"type": "event", "source": "emr", "event": "appointment.scheduled"}],
  "nodes": [
    {"id": "1", "type": "trigger", "name": "Appointment Scheduled", "config": {"source": "emr"}},
    {"id": "2", "type": "emr", "name": "Get Patient Insurance", "config": {"action": "get_insurance_details"}},
    {"id": "3", "type": "ai_agent", "name": "Verify Eligibility", "config": {"agent": "healthcare_agent", "prompt": "Verify insurance eligibility with provider: coverage, copay, pre-auth requirements."}},
    {"id": "4", "type": "condition", "name": "Covered?", "config": {"field": "insurance.eligible"}},
    {"id": "5a", "type": "email", "name": "Notify Patient - Covered", "config": {"template": "insurance_confirmed"}},
    {"id": "5b", "type": "email", "name": "Notify Patient - Not Covered", "config": {"template": "insurance_issue"}},
    {"id": "6", "type": "condition", "name": "Pre-auth Required?", "config": {"field": "insurance.pre_auth_required"}},
    {"id": "7", "type": "action", "name": "Submit Pre-auth", "config": {"action": "submit_preauthorization"}},
    {"id": "8", "type": "twin", "name": "Update Patient Twin", "config": {"twin": "patient_twin", "action": "update_insurance"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5a", "condition": "eligible == true"},
    {"from": "4", "to": "5b", "condition": "eligible == false"},
    {"from": "5a", "to": "6"},
    {"from": "6", "to": "7", "condition": "pre_auth == true"},
    {"from": "6", "to": "8"},
    {"from": "7", "to": "8"}
  ],
  "agents": ["healthcare_agent"],
  "integrations": ["emr", "insurance_api", "email"],
  "estimated_setup_time": "3 hours",
  "price": {"subscription": 1999, "currency": "INR", "period": "month"},
  "tags": ["healthcare", "insurance", "automation", "verification"]
}
