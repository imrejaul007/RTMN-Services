{
  "id": "restaurant-loyalty-automation",
  "name": "Customer Loyalty Automation",
  "category": "restaurant",
  "description": "Automate loyalty rewards, birthday offers, and re-engagement campaigns",
  "version": "1.0.0",
  "triggers": [{"type": "schedule", "cron": "0 10 * * *"}],
  "nodes": [
    {"id": "1", "type": "crm", "name": "Get Loyalty Members", "config": {"action": "get_loyalty_members", "filter": {"tier": ["bronze", "silver", "gold"]}}},
    {"id": "2", "type": "ai_agent", "name": "Identify Campaigns", "config": {"agent": "marketing_agent", "prompt": "Identify: birthday rewards, tier upgrades, inactive members, milestones."}},
    {"id": "3", "type": "condition", "name": "Campaign Type", "config": {"field": "campaign.type"}},
    {"id": "4a", "type": "whatsapp", "name": "Send Birthday Offer", "config": {"template": "birthday_reward"}},
    {"id": "4b", "type": "whatsapp", "name": "Send Tier Upgrade", "config": {"template": "tier_upgrade"}},
    {"id": "4c", "type": "whatsapp", "name": "Send Win-back", "config": {"template": "win_back_offer", "condition": "days_since_visit > 30"}},
    {"id": "5", "type": "crm", "name": "Update Loyalty", "config": {"action": "update_loyalty_points"}},
    {"id": "6", "type": "twin", "name": "Update Customer Twin", "config": {"twin": "customer_twin", "action": "update_loyalty"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4a", "condition": "type == birthday"},
    {"from": "3", "to": "4b", "condition": "type == tier_upgrade"},
    {"from": "3", "to": "4c", "condition": "type == win_back"},
    {"from": "4a", "to": "5"},
    {"from": "4b", "to": "5"},
    {"from": "4c", "to": "5"},
    {"from": "5", "to": "6"}
  ],
  "agents": ["marketing_agent"],
  "integrations": ["whatsapp", "crm"],
  "estimated_setup_time": "2 hours",
  "price": {"subscription": 1499, "currency": "INR", "period": "month"},
  "tags": ["restaurant", "loyalty", "automation", "marketing"]
}
