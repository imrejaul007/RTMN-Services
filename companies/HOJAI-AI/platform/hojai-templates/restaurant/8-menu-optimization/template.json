{
  "id": "restaurant-menu-optimization",
  "name": "Menu Optimization",
  "category": "restaurant",
  "description": "AI-powered menu engineering based on profitability and popularity",
  "version": "1.0.0",
  "triggers": [{"type": "schedule", "cron": "0 6 * * 1"}],
  "nodes": [
    {"id": "1", "type": "pos", "name": "Get Sales Data", "config": {"action": "get_item_sales", "period": "30d"}},
    {"id": "2", "type": "inventory", "name": "Get Food Costs", "config": {"action": "get_food_costs"}},
    {"id": "3", "type": "ai_agent", "name": "Analyze Menu", "config": {"agent": "analytics_agent", "prompt": "Calculate food cost %, contribution margin, popularity for each menu item."}},
    {"id": "4", "type": "ai_agent", "name": "Generate Recommendations", "config": {"agent": "analytics_agent", "prompt": "Recommend: items to highlight, items to modify, items to remove."}},
    {"id": "5", "type": "approval", "name": "Chef Review", "config": {"approvers": ["executive_chef"]}},
    {"id": "6", "type": "document", "name": "Update Menu", "config": {"action": "update_menu", "changes": "{{changes}}"}}
  ],
  "connections": [
    {"from": "1", "to": "3"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5"},
    {"from": "5", "to": "6", "condition": "approved"}
  ],
  "agents": ["analytics_agent"],
  "integrations": ["pos", "inventory"],
  "estimated_setup_time": "2 hours",
  "price": {"subscription": 1499, "currency": "INR", "period": "month"},
  "tags": ["restaurant", "menu", "optimization", "profit"]
}
