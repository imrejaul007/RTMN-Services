{
  "id": "restaurant-delivery-tracking",
  "name": "Delivery Tracking & Analytics",
  "category": "restaurant",
  "description": "Track delivery performance and optimize delivery times",
  "version": "1.0.0",
  "triggers": [{"type": "schedule", "cron": "0 */4 * * *"}],
  "nodes": [
    {"id": "1", "type": "delivery", "name": "Get Delivery Status", "config": {"action": "get_active_deliveries"}},
    {"id": "2", "type": "condition", "name": "Delayed?", "config": {"field": "order.delivery_time_remaining", "operator": "<", "value": 0}},
    {"id": "3", "type": "slack", "name": "Alert Kitchen", "config": {"channel": "kitchen", "template": "rush_order", "condition": "delayed"}},
    {"id": "4", "type": "whatsapp", "name": "Notify Customer", "config": {"template": "delay_apology", "condition": "delay > 15"}},
    {"id": "5", "type": "analytics", "name": "Track Metrics", "config": {"action": "log_delivery_time"}},
    {"id": "6", "type": "twin", "name": "Update Delivery Twin", "config": {"twin": "delivery_twin", "action": "update"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3", "condition": "delayed == true"},
    {"from": "2", "to": "5"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5"},
    {"from": "5", "to": "6"}
  ],
  "agents": [],
  "integrations": ["delivery_api", "slack", "whatsapp"],
  "estimated_setup_time": "2 hours",
  "price": {"subscription": 999, "currency": "INR", "period": "month"},
  "tags": ["restaurant", "delivery", "operations", "automation"]
}
