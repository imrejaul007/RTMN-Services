{
  "id": "marketing-content-calendar",
  "name": "AI Content Calendar",
  "category": "marketing",
  "description": "Automatically generate and schedule content across all social platforms",
  "version": "1.0.0",
  "triggers": [{"type": "schedule", "cron": "0 9 * * 1"}],
  "nodes": [
    {"id": "1", "type": "ai_agent", "name": "Generate Topics", "config": {"agent": "content_agent", "prompt": "Generate 7 content topics for the week based on: trends, product updates, audience interests."}},
    {"id": "2", "type": "ai_agent", "name": "Create Content", "config": {"agent": "content_agent", "prompt": "Create social media posts for each topic, optimized for each platform."}},
    {"id": "3", "type": "transform", "name": "Format for Platforms", "config": {"formats": ["linkedin", "twitter", "instagram", "facebook"]}},
    {"id": "4", "type": "approval", "name": "Content Approval", "config": {"approvers": ["marketing_manager"], "timeout_hours": 24}},
    {"id": "5", "type": "schedule", "name": "Queue Posts", "config": {"scheduler": "buffer", "distribute": true}},
    {"id": "6", "type": "crm", "name": "Link to Campaign", "config": {"action": "link_to_campaign", "fields": ["content", "platform", "scheduled_time"]}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5", "condition": "approved"},
    {"from": "5", "to": "6"}
  ],
  "agents": ["content_agent"],
  "integrations": ["buffer", "linkedin", "twitter", "instagram", "crm"],
  "estimated_setup_time": "30 minutes",
  "price": {"subscription": 1999, "currency": "INR", "period": "month"},
  "tags": ["marketing", "content", "automation", "social-media"]
}
