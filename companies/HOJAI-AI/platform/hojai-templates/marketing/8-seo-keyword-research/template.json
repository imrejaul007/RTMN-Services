{
  "id": "marketing-seo-keyword-research",
  "name": "SEO Keyword Research Automation",
  "category": "marketing",
  "description": "Automatically research keywords, analyze competitors, and generate content briefs",
  "version": "1.0.0",
  "triggers": [{"type": "schedule", "cron": "0 6 * * 3"}],
  "nodes": [
    {"id": "1", "type": "actor", "name": "Google Trends", "config": {"actor": "google_trends", "keywords": "{{seed_keywords}}"}},
    {"id": "2", "type": "actor", "name": "Competitor Analysis", "config": {"actor": "competitor_actor", "targets": "{{competitor_sites}}"}},
    {"id": "3", "type": "ai_agent", "name": "Analyze Keywords", "config": {"agent": "seo_agent", "prompt": "Analyze keywords for search volume, difficulty, and opportunity."}},
    {"id": "4", "type": "ai_agent", "name": "Generate Content Brief", "config": {"agent": "content_agent", "prompt": "Create SEO content brief with target keywords, headings, and questions."}},
    {"id": "5", "type": "approval", "name": "Editorial Review", "config": {"approvers": ["content_editor"]}},
    {"id": "6", "type": "cms", "name": "Add to Content Calendar", "config": {"action": "create_task", "type": "seo_content"}},
    {"id": "7", "type": "memory", "name": "Save Keywords", "config": {"action": "save", "memory_type": "keyword_research"}}
  ],
  "connections": [
    {"from": "1", "to": "3"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5"},
    {"from": "5", "to": "6", "condition": "approved"},
    {"from": "6", "to": "7"}
  ],
  "agents": ["seo_agent", "content_agent"],
  "integrations": ["google_search", "cms", "memory"],
  "estimated_setup_time": "30 minutes",
  "price": {"subscription": 1999, "currency": "INR", "period": "month"},
  "tags": ["marketing", "seo", "keyword-research", "content"]
}
