{
  "id": "founder-competitor-intel",
  "name": "Competitor Intelligence",
  "category": "founder",
  "description": "Monitor competitors for funding, product launches, and news",
  "version": "1.0.0",
  "triggers": [{"type": "schedule", "cron": "0 8 * * *"}],
  "nodes": [
    {"id": "1", "type": "actor", "name": "Monitor News", "config": {"actor": "news", "topics": "{{competitors}}"}},
    {"id": "2", "type": "actor", "name": "Track Funding", "config": {"actor": "news", "topics": "funding rounds"}},
    {"id": "3", "type": "ai_agent", "name": "Analyze Signals", "config": {"agent": "research_agent", "prompt": "Analyze competitor news: funding implications, product threats, market shifts."}},
    {"id": "4", "type": "condition", "name": "Major News?", "config": {"field": "significance", "operator": ">=", "value": "high"}},
    {"id": "5a", "type": "slack", "name": "Alert Team", "config": {"channel": "strategy", "template": "competitor_alert"}},
    {"id": "5b", "type": "memory", "name": "Log to Feed", "config": {"action": "save", "memory_type": "competitor_news"}},
    {"id": "6", "type": "twin", "name": "Update Twin", "config": {"twin": "competitor_twin", "action": "update_news"}}
  ],
  "connections": [
    {"from": "1", "to": "3"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5a", "condition": "significant == true"},
    {"from": "4", "to": "5b", "condition": "significant == false"},
    {"from": "5a", "to": "6"},
    {"from": "5b", "to": "6"}
  ],
  "agents": ["research_agent"],
  "integrations": ["news_api", "slack", "memory"],
  "estimated_setup_time": "1 hour",
  "price": {"subscription": 999, "currency": "INR", "period": "month"},
  "tags": ["founder", "competitors", "intelligence", "monitoring"]
}
