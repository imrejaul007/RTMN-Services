{
  "id": "founder-goal-tracker",
  "name": "OKR Goal Tracker",
  "category": "founder",
  "description": "Track OKR progress and send weekly updates to team",
  "version": "1.0.0",
  "triggers": [{"type": "schedule", "cron": "0 9 * * 1"}],
  "nodes": [
    {"id": "1", "type": "crm", "name": "Get Sales OKRs", "config": {"action": "get_okrs", "department": "sales"}},
    {"id": "2", "type": "finance", "name": "Get Finance OKRs", "config": {"action": "get_okrs", "department": "finance"}},
    {"id": "3", "type": "hris", "name": "Get HR OKRs", "config": {"action": "get_okrs", "department": "hr"}},
    {"id": "4", "type": "ai_agent", "name": "Calculate Progress", "config": {"agent": "report_agent", "prompt": "Calculate OKR progress: current vs target, confidence level."}},
    {"id": "5", "type": "slack", "name": "Team Update", "config": {"channel": "leadership", "template": "okr_update"}},
    {"id": "6", "type": "twin", "name": "Update Company Twin", "config": {"twin": "company_twin", "action": "update_okrs"}}
  ],
  "connections": [
    {"from": "1", "to": "4"},
    {"from": "2", "to": "4"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5"},
    {"from": "5", "to": " "}
  ],
  "agents": ["report_agent"],
  "integrations": ["crm", "finance", "hris", "slack"],
  "estimated_setup_time": "1 hour",
  "price": {"subscription": 999, "currency": "INR", "period": "month"},
  "tags": ["founder", "okr", "goals", "automation"]
}
