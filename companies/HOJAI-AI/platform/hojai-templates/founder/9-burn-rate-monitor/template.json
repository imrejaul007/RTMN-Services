{
  "id": "founder-burn-rate-monitor",
  "name": "Burn Rate Monitor",
  "category": "founder",
  "description": "Monitor burn rate with AI insights on cost optimization",
  "version": "1.0.0",
  "triggers": [{"type": "schedule", "cron": "0 9 * * 1"}],
  "nodes": [
    {"id": "1", "type": "finance", "name": "Get Financials", "config": {"action": "get_monthly_burn"}},
    {"id": "2", "type": "ai_agent", "name": "Analyze Burn", "config": {"agent": "analytics_agent", "prompt": "Analyze burn rate vs budget. Identify: variances, anomalies, optimization opportunities."}},
    {"id": "3", "type": "condition", "name": "Over Budget?", "config": {"field": "variance.pct", "operator": ">", "value": 10}},
    {"id": "4a", "type": "slack", "name": "Alert", "config": {"channel": "founder", "template": "burn_alert"}},
    {"id": "4b", "type": "email", "name": "Weekly Report", "config": {"to": "founder@company.com", "template": "burn_report"}},
    {"id": "5", "type": "twin", "name": "Update Finance Twin", "config": {"twin": "finance_twin", "action": "update_burn"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4a", "condition": "over == true"},
    {"from": "3", "to": "4b", "condition": "over == false"},
    {"from": "4a", "to": "5"},
    {"from": "4b", "to": "5"}
  ],
  "agents": ["analytics_agent"],
  "integrations": ["finance", "slack", "email"],
  "estimated_setup_time": "1 hour",
  "price": {"subscription": 499, "currency": "INR", "period": "month"},
  "tags": ["founder", "finance", "burn-rate", "monitoring"]
}
