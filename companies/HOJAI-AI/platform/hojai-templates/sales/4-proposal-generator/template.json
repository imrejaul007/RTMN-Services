{
  "id": "sales-proposal-generator",
  "name": "AI Proposal Generator",
  "category": "sales",
  "description": "Generate personalized proposals from templates with prospect data, pricing, and terms",
  "version": "1.0.0",
  "triggers": [
    {
      "type": "event",
      "source": "crm",
      "event": "deal.stage_changed",
      "condition": {"new_stage": "proposal"}
    }
  ],
  "nodes": [
    {"id": "1", "type": "trigger", "name": "Deal Ready", "config": {"source": "crm", "trigger_on": "stage_change"}},
    {"id": "2", "type": "crm", "name": "Load Deal Data", "config": {"action": "get_deal", "fields": ["company", "contact", "products", "budget", "timeline"]}},
    {"id": "3", "type": "ai_agent", "name": "Research Company", "config": {"agent": "research_agent", "prompt": "Research company for proposal personalization. Include: recent news, competitors, team size."}},
    {"id": "4", "type": "ai_agent", "name": "Generate Proposal", "config": {"agent": "proposal_writer", "prompt": "Generate proposal using template, incorporating deal data and research."}},
    {"id": "5", "type": "condition", "name": "High Value?", "config": {"field": "deal.value", "operator": ">=", "value": 100000}},
    {"id": "6a", "type": "approval", "name": "Manager Approval", "config": {"approvers": ["sales_manager"], "timeout_hours": 24}},
    {"id": "6b", "type": "action", "name": "Auto-Approve", "config": {"action": "approve", "condition": "auto_approve"}},
    {"id": "7", "type": "document", "name": "Generate PDF", "config": {"format": "pdf", "template": "sales_proposal"}},
    {"id": "8", "type": "email", "name": "Send Proposal", "config": {"template": "proposal_email", "attach_pdf": true}},
    {"id": "9", "type": "crm", "name": "Log Activity", "config": {"action": "add_note", "note_type": "proposal_sent"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5"},
    {"from": "5", "to": "6a", "condition": "value >= 100000"},
    {"from": "5", "to": "6b", "condition": "value < 100000"},
    {"from": "6a", "to": "7", "condition": "approved"},
    {"from": "6b", "to": "7"},
    {"from": "7", "to": "8"},
    {"from": "8", "to": "9"}
  ],
  "agents": ["research_agent", "proposal_writer"],
  "integrations": ["crm", "email", "document_generator"],
  "estimated_setup_time": "1 hour",
  "price": {"subscription": 2499, "currency": "INR", "period": "month"},
  "tags": ["sales", "proposal", "automation", "document-generation"]
}
