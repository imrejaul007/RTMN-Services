{
  "id": "sales-renewal-alert",
  "name": "Renewal Reminder System",
  "category": "sales",
  "description": "Proactive renewal reminders with sentiment analysis and risk scoring",
  "version": "1.0.0",
  "triggers": [{"type": "schedule", "cron": "0 9 * * *"}],
  "nodes": [
    {"id": "1", "type": "crm", "name": "Find Renewals", "config": {"action": "get_renewals", "lookahead_days": 90}},
    {"id": "2", "type": "filter", "name": "Filter High Risk", "config": {"conditions": [{"field": "days_to_renewal", "operator": "<=", "value": 30}]}},
    {"id": "3", "type": "ai_agent", "name": "Analyze Risk", "config": {"agent": "analyst_agent", "prompt": "Assess renewal risk based on: usage, support tickets, sentiment, payment history."}},
    {"id": "4", "type": "condition", "name": "Risk Level?", "config": {"field": "risk.level"}},
    {"id": "5a", "type": "slack", "name": "Escalate High Risk", "config": {"channel": "account-managers", "template": "renewal_risk"}},
    {"id": "5b", "type": "email", "name": "Send Reminder", "config": {"provider": "smtp", "template": "renewal_reminder"}},
    {"id": "6", "type": "crm", "name": "Create Task", "config": {"action": "create_task", "type": "renewal_checkin"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5a", "condition": "risk == high"},
    {"from": "4", "to": "5b", "condition": "risk == medium"},
    {"from": "4", "to": "6", "condition": "risk == low"},
    {"from": "5a", "to": "6"},
    {"from": "5b", "to": "6"}
  ],
  "agents": ["analyst_agent"],
  "integrations": ["crm", "slack", "email"],
  "estimated_setup_time": "20 minutes",
  "price": {"subscription": 999, "currency": "INR", "period": "month"},
  "tags": ["sales", "renewal", "churn-prevention", "automation"]
}
