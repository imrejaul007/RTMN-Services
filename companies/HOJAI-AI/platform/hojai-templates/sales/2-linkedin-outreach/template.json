{
  "id": "sales-linkedin-outreach",
  "name": "LinkedIn AI Outreach",
  "category": "sales",
  "description": "Automatically scrape LinkedIn, qualify prospects, and send personalized outreach",
  "version": "1.0.0",
  "triggers": [
    {
      "type": "schedule",
      "cron": "0 9 * * 1-5"
    }
  ],
  "nodes": [
    {
      "id": "1",
      "type": "actor",
      "name": "LinkedIn Scraper",
      "config": {
        "actor": "linkedin_company",
        "target": "prospects",
        "filters": ["industry", "company_size", "job_title"]
      }
    },
    {
      "id": "2",
      "type": "filter",
      "name": "Filter Duplicates",
      "config": {
        "dedupe_on": ["linkedin_url"]
      }
    },
    {
      "id": "3",
      "type": "ai_agent",
      "name": "Personalize Message",
      "config": {
        "agent": "outreach_agent",
        "model": "claude-3-5-sonnet",
        "prompt": "Generate personalized LinkedIn message based on prospect profile and recent activity."
      }
    },
    {
      "id": "4",
      "type": "action",
      "name": "Send LinkedIn Message",
      "config": {
        "action": "send_message",
        "platform": "linkedin"
      }
    },
    {
      "id": "5",
      "type": "memory",
      "name": "Update Outreach History",
      "config": {
        "action": "save",
        "memory_type": "interaction"
      }
    },
    {
      "id": "6",
      "type": "crm",
      "name": "Log Activity",
      "config": {
        "action": "add_activity",
        "activity_type": "linkedin_outreach"
      }
    }
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5"},
    {"from": "4", "to": "6"}
  ],
  "memory": {
    "required": ["outreach_history", "message_templates"],
    "update_on": ["message_sent"]
  },
  "twins": {
    "creates": ["prospect_twin"],
    "updates": ["prospect_twin"]
  },
  "agents": ["outreach_agent"],
  "integrations": ["linkedin", "crm"],
  "estimated_setup_time": "1 hour",
  "price": {
    "subscription": 1499,
    "currency": "INR",
    "period": "month"
  },
  "tags": ["sales", "outreach", "linkedin", "automation"]
}
