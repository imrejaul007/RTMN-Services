{
  "id": "sales-competitor-monitor",
  "name": "Competitor Monitoring",
  "category": "sales",
  "description": "Track competitor pricing, products, and news automatically",
  "version": "1.0.0",
  "triggers": [
    {"type": "schedule", "cron": "0 */6 * * *"}
  ],
  "nodes": [
    {"id": "1", "type": "watcher", "name": "Price Watcher", "config": {"actors": ["competitor_a", "competitor_b"], "watch": ["pricing", "discounts"]}},
    {"id": "2", "type": "watcher", "name": "Product Watcher", "config": {"actors": ["competitor_a", "competitor_b"], "watch": ["new_products", "features"]}},
    {"id": "3", "type": "actor", "name": "News Scraper", "config": {"actor": "news_actor", "sources": ["competitor_news"]}},
    {"id": "4", "type": "ai_agent", "name": "Analyze Changes", "config": {"agent": "analyst_agent", "prompt": "Analyze competitor changes and determine impact on our positioning."}},
    {"id": "5", "type": "condition", "name": "Major Change?", "config": {"field": "change.significance", "operator": ">=", "value": "high"}},
    {"id": "6a", "type": "notification", "name": "Alert Sales Team", "config": {"channel": "slack", "template": "competitor_alert"}},
    {"id": "6b", "type": "memory", "name": "Log to Memory", "config": {"action": "save", "memory_type": "competitor_intel"}},
    {"id": "7", "type": "twin", "name": "Update Competitor Twin", "config": {"twin": "competitor_twin", "action": "update"}}
  ],
  "connections": [
    {"from": "1", "to": "4"},
    {"from": "2", "to": "4"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5"},
    {"from": "5", "to": "6a", "condition": "significant == true"},
    {"from": "5", "to": "6b", "condition": "significant == false"},
    {"from": "6a", "to": "7"},
    {"from": "6b", "to": "7"}
  ],
  "agents": ["analyst_agent"],
  "integrations": ["slack", "memory", "twin"],
  "estimated_setup_time": "1 hour",
  "price": {"subscription": 1999, "currency": "INR", "period": "month"},
  "tags": ["sales", "intelligence", "competitor", "monitoring"]
}
