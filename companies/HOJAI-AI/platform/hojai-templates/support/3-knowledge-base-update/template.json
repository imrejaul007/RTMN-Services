{
  "id": "support-knowledge-base-auto-update",
  "name": "Knowledge Base Auto-Update",
  "category": "support",
  "description": "Automatically update knowledge base from support tickets and resolutions",
  "version": "1.0.0",
  "triggers": [{"type": "event", "source": "helpdesk", "event": "ticket.resolved"}],
  "nodes": [
    {"id": "1", "type": "trigger", "name": "Ticket Resolved", "config": {"source": "helpdesk"}},
    {"id": "2", "type": "condition", "name": "New Issue?", "config": {"field": "ticket.is_new_topic", "operator": "==", "value": true}},
    {"id": "3", "type": "ai_agent", "name": "Generate Article", "config": {"agent": "support_agent", "prompt": "Generate knowledge base article from resolved ticket. Include: problem, solution, steps."}},
    {"id": "4", "type": "approval", "name": "Editor Review", "config": {"approvers": ["support_manager"], "timeout": 48}},
    {"id": "5", "type": "action", "name": "Publish to KB", "config": {"action": "publish_article"}},
    {"id": "6", "type": "crm", "name": "Link to Ticket", "config": {"action": "update_ticket", "field": "kb_article_created"}},
    {"id": "7", "type": "memory", "name": "Track Topics", "config": {"action": "save", "memory_type": "kb_topics"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3", "condition": "is_new == true"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5", "condition": "approved"},
    {"from": "5", "to": "6"},
    {"from": "6", "to": "7"}
  ],
  "agents": ["support_agent"],
  "integrations": ["helpdesk", "knowledge_base", "crm"],
  "estimated_setup_time": "30 minutes",
  "price": {"subscription": 999, "currency": "INR", "period": "month"},
  "tags": ["support", "knowledge-base", "automation", "self-service"]
}
