{
  "id": "support-escalation-rules",
  "name": "Smart Escalation Rules",
  "category": "support",
  "description": "Intelligent escalation based on ticket priority, customer tier, and SLA",
  "version": "1.0.0",
  "triggers": [{"type": "schedule", "cron": "0 */15 * * * *"}],
  "nodes": [
    {"id": "1", "type": "crm", "name": "Get Open Tickets", "config": {"action": "get_tickets", "filter": {"status": "open"}}},
    {"id": "2", "type": "ai_agent", "name": "Assess Priority", "config": {"agent": "support_agent", "prompt": "Assess ticket priority based on: age, SLA breach risk, customer tier, sentiment."}},
    {"id": "3", "type": "condition", "name": "SLA At Risk?", "config": {"field": "sla.breach_risk", "operator": ">=", "value": 80}},
    {"id": "4a", "type": "action", "name": "Escalate", "config": {"action": "escalate", "level": "manager"}},
    {"id": "4b", "type": "action", "name": "Add Resources", "config": {"action": "add_resources", "agents": 2}},
    {"id": "5", "type": "slack", "name": "Notify Team", "config": {"channel": "support-urgent", "template": "sla_alert"}},
    {"id": "6", "type": "crm", "name": "Update Ticket", "config": {"action": "update_ticket", "field": "escalation_level"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "2", "to": "3"},
    {"from": "3", "to": "4a", "condition": "breach_risk >= 80"},
    {"from": "3", "to": "4b", "condition": "breach_risk < 80"},
    {"from": "4a", "to": "5"},
    {"from": "4b", "to": "5"},
    {"from": "5", "to": "6"}
  ],
  "agents": ["support_agent"],
  "integrations": ["crm", "slack"],
  "estimated_setup_time": "20 minutes",
  "price": {"subscription": 999, "currency": "INR", "period": "month"},
  "tags": ["support", "escalation", "sla", "automation"]
}
