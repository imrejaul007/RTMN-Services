{
  "id": "commerce-supplier-discovery",
  "name": "AI Supplier Discovery",
  "category": "commerce",
  "description": "Automatically discover and evaluate new suppliers based on requirements",
  "version": "1.0.0",
  "triggers": [{"type": "event", "source": "erp", "event": "rfq.created"}],
  "nodes": [
    {"id": "1", "type": "trigger", "name": "New RFQ", "config": {"source": "erp"}},
    {"id": "2", "type": "actor", "name": "Search Suppliers", "config": {"actor": "google_maps", "query": "{{product_category}} suppliers"}},
    {"id": "3", "type": "actor", "name": "LinkedIn Search", "config": {"actor": "linkedin", "query": "{{product_category}} manufacturers"}},
    {"id": "4", "type": "ai_agent", "name": "Evaluate Suppliers", "config": {"agent": "procurement_agent", "prompt": "Evaluate suppliers: capacity, certifications, reviews, pricing."}},
    {"id": "5", "type": "filter", "name": "Top 5", "config": {"conditions": [{"field": "score", "operator": ">=", "value": 70}]}},
    {"id": "6", "type": "crm", "name": "Create Suppliers", "config": {"action": "create_suppliers"}},
    {"id": "7", "type": "email", "name": "Send RFQ", "config": {"to": "{{suppliers}}", "template": "rfq_invitation"}}
  ],
  "connections": [
    {"from": "1", "to": "2"},
    {"from": "1", "to": "3"},
    {"from": "2", "to": "4"},
    {"from": "3", "to": "4"},
    {"from": "4", "to": "5"},
    {"from": "5", "to": "6"},
    {"from": "6", "to": "7"}
  ],
  "agents": ["procurement_agent"],
  "integrations": ["erp", "actor_runtime", "crm", "email"],
  "estimated_setup_time": "3 hours",
  "price": {"subscription": 3999, "currency": "INR", "period": "month"},
  "tags": ["commerce", "procurement", "supplier", "automation"]
}
