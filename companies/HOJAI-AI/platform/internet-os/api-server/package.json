{
  "name": "@hojai/internet-os-api",
  "version": "1.0.0",
  "description": "HOJAI InternetOS API Server - Web intelligence gateway",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "dev:server": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["hojai", "internet-os", "api", "web-scraping", "intelligence"],
  "author": "HOJAI AI",
  "license": "MIT",
  "dependencies": {
    "@hojai/actor-runtime": "^1.0.0",
    "@hojai/watcher-runtime": "^1.0.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "vitest": "^1.3.0"
  }
}
