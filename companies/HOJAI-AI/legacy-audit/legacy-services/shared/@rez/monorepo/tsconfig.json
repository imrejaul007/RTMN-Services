{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "composite": true,
    "incremental": true,
    "paths": {
      "@rez/mongodb": ["./mongodb/src"],
      "@rez/redis": ["./redis/src"],
      "@rez/logger": ["./logger/src"],
      "@rez/security": ["./security/src"],
      "@rez/validation": ["./validation/src"]
    }
  },
  "references": [
    { "path": "./mongodb" },
    { "path": "./redis" },
    { "path": "./logger" },
    { "path": "./security" },
    { "path": "./validation" }
  ],
  "include": [],
  "exclude": ["node_modules", "dist"]
}
