{
  "name": "@rez/redis",
  "version": "1.0.0",
  "description": "Production-ready Redis client with circuit breakers, rate limiting, and distributed locks for RTNM services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "ioredis": "^5.4.1"
  },
  "peerDependencies": {
    "express": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "@types/express": "^4.17.21"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "redis",
    "rate-limiting",
    "circuit-breaker",
    "distributed-lock",
    "caching",
    "sessions"
  ]
}