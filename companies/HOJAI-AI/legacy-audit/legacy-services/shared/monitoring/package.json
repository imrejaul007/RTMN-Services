{
  "name": "@rez/monitoring",
  "version": "1.0.0",
  "description": "Production-ready observability package with Prometheus metrics, health checks, SLO tracking, and distributed tracing for RTNM services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
