{
  "name": "@hojai/agent-sdk",
  "version": "1.0.0",
  "description": "Base SDK for HOJAI AI agents with persona, tools, memory, and event bus integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./persona": {
      "import": "./dist/persona.js",
      "types": "./dist/persona.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    },
    "./memory": {
      "import": "./dist/memory.js",
      "types": "./dist/memory.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "hojai",
    "ai-agent",
    "agent-sdk"
  ],
  "author": "HOJAI AI",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "zod": "^3.22.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@hojai/memory": "*",
    "@hojai/event": "*",
    "@hojai/llm": "*"
  }
}
