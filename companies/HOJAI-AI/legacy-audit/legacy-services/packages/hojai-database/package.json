{
  "name": "@hojai/database",
  "version": "1.0.0",
  "description": "HOJAI Database - MongoDB connection and utilities",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./connection": {
      "import": "./dist/connection.mjs",
      "require": "./dist/connection.js",
      "types": "./dist/connection.d.ts"
    },
    "./repositories": {
      "import": "./dist/repositories/index.mjs",
      "require": "./dist/repositories/index.js",
      "types": "./dist/repositories/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["hojai", "database", "mongodb", "persistence"],
  "author": "HOJAI AI",
  "license": "MIT",
  "dependencies": {
    "mongoose": "^8.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
