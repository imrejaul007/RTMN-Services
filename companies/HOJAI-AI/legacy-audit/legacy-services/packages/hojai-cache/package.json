{
  "name": "@hojai/cache",
  "version": "1.0.0",
  "description": "HOJAI Cache - Redis caching utilities",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./redis": {
      "import": "./dist/redis.mjs",
      "require": "./dist/redis.js",
      "types": "./dist/redis.d.ts"
    },
    "./memory": {
      "import": "./dist/memory-cache.mjs",
      "require": "./dist/memory-cache.js",
      "types": "./dist/memory-cache.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["hojai", "cache", "redis", "memory"],
  "author": "HOJAI AI",
  "license": "MIT",
  "dependencies": {
    "redis": "^4.6.10",
    "lru-cache": "^10.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
