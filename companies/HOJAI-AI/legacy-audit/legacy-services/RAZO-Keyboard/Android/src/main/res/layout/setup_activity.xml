<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <!-- Logo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎹"
        android:textSize="72sp"
        android:layout_marginBottom="16dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_title"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#333333" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_subtitle"
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginBottom="32dp" />

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/setup_progress"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#007AFF" />

    <!-- Status -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ready to setup"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp" />

    <!-- Setup Steps -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✓ Enable RAZO as your keyboard"
            android:textSize="14sp"
            android:textColor="#333333"
            android:drawableStart="@android:drawable/checkbox_on_background"
            android:drawablePadding="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="○ Enable Accessibility Service"
            android:textSize="14sp"
            android:textColor="#666666"
            android:drawableStart="@android:drawable/checkbox_off_background"
            android:drawablePadding="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="○ Authenticate with CorpID"
            android:textSize="14sp"
            android:textColor="#666666"
            android:drawableStart="@android:drawable/checkbox_off_background"
            android:drawablePadding="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="○ Setup Biometric (optional)"
            android:textSize="14sp"
            android:textColor="#666666"
            android:drawableStart="@android:drawable/checkbox_off_background"
            android:drawablePadding="8dp" />

    </LinearLayout>

    <!-- Buttons -->
    <Button
        android:id="@+id/setup_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Setup"
        android:textSize="16sp"
        android:backgroundTint="#007AFF"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/skip_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Skip (Offline Mode)"
        android:textSize="14sp"
        style="@style/Widget.MaterialComponents.Button.TextButton" />

</LinearLayout>
