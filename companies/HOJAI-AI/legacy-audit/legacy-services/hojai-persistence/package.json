{
  "name": "@hojai/persistence",
  "version": "1.0.0",
  "description": "MongoDB persistence layer for HOJAI AI - Agent and Memory repositories",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./repositories": {
      "import": "./dist/repositories/index.js",
      "types": "./dist/repositories/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "mongodb": "^6.5.0",
    "zod": "^3.22.4",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/mongodb": "^4.0.7",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^1.4.0",
    "ts-node-dev": "^2.0.0",
    "mongodb-memory-server": "^9.1.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "hojai",
    "persistence",
    "mongodb",
    "repository",
    "agent",
    "memory"
  ],
  "author": "HOJAI AI",
  "license": "MIT"
}
