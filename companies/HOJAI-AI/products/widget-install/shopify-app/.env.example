# Shopify App Configuration
# Copy this file to .env and fill in your values

# ===========================================
# SHOPIFY APP CREDENTIALS
# ===========================================
# Get these from your Shopify Partner Dashboard
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret

# Shopify API Scopes (comma-separated)
# See: https://shopify.dev/docs/api/usage/access-scopes
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_customers,read_analytics,read_themes,write_themes

# Your app's URL (must be HTTPS in production)
# For local development, use ngrok or similar
SHOPIFY_APP_URL=https://your-app-url.ngrok.io

# ===========================================
# APP CONFIGURATION
# ===========================================
# Node environment
NODE_ENV=development

# Server port
PORT=3000

# ===========================================
# HOJAI PLATFORM CONFIGURATION
# ===========================================
# HOJAI Platform API credentials
HOJAI_API_KEY=your_hojai_api_key
HOJAI_API_SECRET=your_hojai_api_secret
HOJAI_PLATFORM_URL=https://api.hojai.ai

# HOJAI Widget CDN URL
HOJAI_WIDGET_URL=https://cdn.hojai.ai/widget.js

# HOJAI Widget API URL
HOJAI_WIDGET_API_URL=https://api.hojai.ai/widget

# ===========================================
# DATABASE CONFIGURATION (Production)
# ===========================================
# PostgreSQL for persistent storage
DATABASE_URL=postgresql://user:password@localhost:5432/hojai_shopify

# Redis for session cache
REDIS_URL=redis://localhost:6379

# ===========================================
# SECURITY
# ===========================================
# JWT secret for session tokens
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Encrypted storage key (32 bytes, base64 encoded)
STORAGE_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ===========================================
# WEBHOOK CONFIGURATION
# ===========================================
# Webhook registration secret (from Shopify)
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

# ===========================================
# OPTIONAL: Third-party Services
# ===========================================

# For email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# For analytics
ANALYTICS_WRITE_KEY=your-segment-write-key

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
# Set to true to skip webhook signature verification (NEVER in production)
SKIP_WEBHOOK_VERIFICATION=false

# Set to true to use mock data instead of real Shopify API calls
USE_MOCK_DATA=false