{
  "name": "@hojai/widget-intelligence",
  "version": "1.0.0",
  "description": "Lead scoring intelligence for HOJAI SiteOS widget",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
