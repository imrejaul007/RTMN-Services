{
  "name": "voice-os-desktop",
  "version": "1.0.0",
  "description": "HOJAI VoiceOS Desktop - Wispr Flow competitor",
  "main": "dist/main/index.js",
  "author": "HOJAI",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "build": "tsc && electron-builder",
    "build:mac": "tsc && electron-builder --mac",
    "build:win": "tsc && electron-builder --win",
    "build:linux": "tsc && electron-builder --linux"
  },
  "build": {
    "appId": "ai.hojai.voiceos",
    "productName": "HOJAI VoiceOS",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.0",
    "electron-log": "^5.0.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0"
  }
}
