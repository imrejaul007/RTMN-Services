{
  "id": "healthcare",
  "name": "Agentic Healthcare",
  "version": "1.0.0",
  "tagline": "AI-powered healthcare like Practo",
  "description": "Full-featured healthcare platform with AI-powered doctor matching, telemedicine, appointment booking, and health records.",
  "category": "healthcare",
  "icon": "🏥",
  "color": "#10B981",
  "sector": "healthcare",

  "crew": {
    "ai_workers": [
      { "role": "SymptomAgent", "salary": 400, "model": "claude-3-sonnet", "skills": ["triage", "symptom-check", "urgency-detection"] },
      { "role": "DoctorMatchAgent", "salary": 350, "model": "claude-3-sonnet", "skills": ["specialty-matching", "availability", "ratings"] },
      { "role": "AppointmentAgent", "salary": 250, "model": "claude-3-haiku", "skills": ["scheduling", "reminders", "rescheduling"] },
      { "role": "PrescriptionAgent", "salary": 300, "model": "claude-3-haiku", "skills": ["e-prescriptions", "pharmacy-matching", "refills"] },
      { "role": "InsuranceAgent", "salary": 350, "model": "claude-3-haiku", "skills": ["claim-processing", "coverage-verification", "tpas"] },
      { "role": "HealthRecordAgent", "salary": 300, "model": "claude-3-haiku", "skills": ["emr", "lab-results", "analytics"] }
    ]
  },

  "total_ai_salary": 1950,

  "flows": [
    { "id": "doctor_appointment", "name": "Doctor Appointment", "trigger": "book_doctor", "steps": ["triage_patient", "find_specialist", "book_slot", "send_reminder"] },
    { "id": "telemedicine", "name": "Telemedicine", "trigger": "start_consultation", "steps": ["prep_history", "connect_video", "generate_prescription"] },
    { "id": "insurance_claims", "name": "Insurance Claims", "trigger": "submit_claim", "steps": ["validate_claim", "process_claim", "notify_patient"] }
  ],

  "nexha_connections": [
    { "network": "healthcare-os", "purpose": "Doctor network, hospitals" },
    { "network": "insurance-network", "purpose": "Claims, coverage" },
    { "network": "pharmacy-network", "purpose": "Medications, delivery" }
  ],

  "apps": {
    "passenger": {
      "name": "{{company}} Patient App",
      "screens": ["Home", "DoctorSearch", "Appointment", "Telemedicine", "Prescriptions", "Profile"],
      "features": ["doctor-search", "appointment-booking", "telemedicine", "prescriptions", "health-records"]
    }
  }
}
