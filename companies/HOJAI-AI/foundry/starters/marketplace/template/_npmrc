# HOJAI Foundry — npm install hints
#
# The HOJAI SDKs (@hojai/*) are part of the monorepo and not yet
# published to the public npm registry. To run this project today,
# the SDKs are optional. The backend boots and serves /health even
# without them, using a built-in fallback for each domain.
#
# Once @hojai/* packages are on npm, delete this file and the
# dependencies will install normally.
registry=https://registry.npmjs.org/
fund=false
audit=false
