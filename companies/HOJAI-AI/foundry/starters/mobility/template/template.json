{
  "id": "mobility",
  "name": "Agentic Mobility",
  "version": "1.0.0",
  "tagline": "AI-powered ride-hailing like Uber/Ola",
  "description": "Full-featured mobility platform with AI-powered driver matching, surge pricing, safety features, and real-time tracking.",
  "category": "mobility",
  "icon": "🚗",
  "color": "#FF6B35",
  "sector": "mobility",

  "crew": {
    "ai_workers": [
      { "role": "DispatchAgent", "salary": 400, "model": "claude-3-sonnet", "skills": ["matching", "surge-pricing", "dispatch", "routing"] },
      { "role": "SafetyAgent", "salary": 350, "model": "claude-3-sonnet", "skills": ["background-checks", "ride-monitoring", "emergency", "insurance"] },
      { "role": "DriverGrowthAgent", "salary": 350, "model": "claude-3-haiku", "skills": ["acquisition", "retention", "incentives", "earnings"] },
      { "role": "RiderGrowthAgent", "salary": 350, "model": "claude-3-haiku", "skills": ["acquisition", "referrals", "engagement", "loyalty"] },
      { "role": "FleetAgent", "salary": 300, "model": "claude-3-haiku", "skills": ["vehicle-management", "maintenance", "insurance", "registration"] },
      { "role": "InsuranceAgent", "salary": 300, "model": "claude-3-haiku", "skills": ["coverage", "claims", "verification"] },
      { "role": "PricingAgent", "salary": 400, "model": "claude-3-sonnet", "skills": ["dynamic-pricing", "surge", "promotions", "discounts"] },
      { "role": "SupportAgent", "salary": 200, "model": "claude-3-haiku", "skills": ["ticket-resolution", "refunds", "complaints", "chatbot"] },
      { "role": "ComplianceAgent", "salary": 250, "model": "claude-3-haiku", "skills": ["license-verification", "regulatory", "local-laws"] },
      { "role": "AnalyticsAgent", "salary": 300, "model": "claude-3-sonnet", "skills": ["dashboards", "cohort-analysis", "forecasting"] },
      { "role": "FreightAgent", "salary": 400, "model": "claude-3-sonnet", "skills": ["cargo-matching", "tracking", "pricing"] },
      { "role": "EatsAgent", "salary": 300, "model": "claude-3-haiku", "skills": ["restaurant-matching", "delivery-optimization"] },
      { "role": "ConfirmationAgent", "salary": 250, "model": "claude-3-haiku", "skills": ["notifications", "receipts", "tips"] }
    ]
  },

  "total_ai_salary": 3800,

  "twins": [
    { "type": "rider", "name": "{{company}} Rider" },
    { "type": "driver", "name": "{{company}} Driver" },
    { "type": "vehicle", "name": "{{company}} Vehicle" },
    { "type": "ride", "name": "{{company}} Ride" },
    { "type": "trip", "name": "{{company}} Trip" }
  ],

  "flows": [
    { "id": "ride_booking", "name": "Ride Booking", "trigger": "ride_request", "steps": ["parse_request", "verify_insurance", "calculate_fare", "find_driver", "pre_authorize", "match_driver", "send_eta"] },
    { "id": "driver_onboarding", "name": "Driver Onboarding", "trigger": "driver_apply", "steps": ["background_check", "verify_license", "approve_driver"] },
    { "id": "surge_pricing", "name": "Surge Pricing", "trigger": "demand_spike", "steps": ["calculate_surge", "notify_drivers"] },
    { "id": "safety_incident", "name": "Safety Incident", "trigger": "incident_detected", "steps": ["assess_incident", "contact_authorities", "file_claim"] }
  ],

  "nexha_connections": [
    { "network": "payment-network", "purpose": "Payments, payouts, tips" },
    { "network": "mobility-os", "purpose": "Maps, routing, ETA" },
    { "network": "insurance-network", "purpose": "Ride insurance, driver coverage" },
    { "network": "logistics-network", "purpose": "Freight, cargo delivery" }
  ],

  "apps": {
    "passenger": {
      "name": "{{company}} Rider App",
      "screens": ["Home", "RideSelection", "TrackDriver", "Payment", "History", "Profile"],
      "features": ["ride-booking", "real-time-tracking", "payment", "ride-history", "safety"]
    },
    "driver": {
      "name": "{{company}} Driver App",
      "screens": ["Home", "RideRequests", "Earnings", "History", "Profile"],
      "features": ["ride-requests", "navigation", "earnings", "status-management"]
    }
  },

  "policies": [
    { "name": "commission_driver", "value": 0.20 },
    { "name": "surge_multiplier_max", "value": 3.0 },
    { "name": "min_fare", "value": 40 },
    { "name": "per_km_rate", "value": 10 },
    { "name": "per_minute_rate", "value": 1 },
    { "name": "safety_buffer_percent", "value": 10 }
  ],

  "pricing": {
    "base_fare": "₹40",
    "per_km": "₹10-15",
    "per_minute": "₹1",
    "surge": "1.5x-3x during peak",
    "booking_fee": "₹10-20"
  }
}
