# Nexha — root .gitignore
# Generated by Phase 1 of NEXHA-DEEP-AUDIT.md

# Secrets — NEVER commit
.env
.env.local
.env.production.local
.env.*.local

# Dependencies
node_modules/

# Build output
dist/
.next/
out/
build/

# Coverage / test artifacts
coverage/
.nyc_output/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# IDE / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo
Thumbs.db

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# Vercel deployment metadata (project IDs leak org structure)
.vercel/

# Render deployment metadata
.render/

# Local-only scripts
scripts/*.local.*
