{
  "name": "@nexha/capability-os",
  "version": "0.1.0",
  "description": "Nexha CapabilityOS — the canonical capability schema + registry for the Nexha federation. Defines what each Nexha offers (skills, services, products, agents) and exposes a unified API for capability discovery + matching.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@rtmn/shared": "file:../../HOJAI-AI/shared",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "nexha",
    "capability",
    "registry",
    "federation",
    "schema"
  ],
