# Server
PORT=8000
NODE_ENV=development
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/nexha_commerce_identity

# SUTAR OS Integration (RTMN trust layer)
# In dev, point all of these at the sutar-mock service (port 4799)
SUTAR_BASE_URL=http://localhost:4799
SUTAR_IDENTITY_URL=http://localhost:4799
SUTAR_REPUTATION_URL=http://localhost:4799
SUTAR_DECISION_URL=http://localhost:4799
SUTAR_EVENT_BUS_URL=http://localhost:4799

# JWT (real auth — must be set to a strong random value in production)
JWT_SECRET=dev-secret-change-me-in-production-please
JWT_EXPIRES_IN=7d
JWT_ISSUER=nexha-commerce-identity
JWT_AUDIENCE=nexha-portal

# Service-to-service auth
INTERNAL_API_KEY=change-me-in-production

# Guest onboarding
GUEST_ID_PREFIX=GST-
GUEST_DEFAULT_VALIDITY_DAYS=30
WHATSAPP_VERIFICATION_REQUIRED=true

# WhatsApp Business API
# Leave WHATSAPP_PROVIDER unset for development (console + event-bus only)
# Set to 'meta' for WhatsApp Business Cloud API
# Set to 'twilio' for Twilio WhatsApp
WHATSAPP_PROVIDER=
# Meta WhatsApp:
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Twilio:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
