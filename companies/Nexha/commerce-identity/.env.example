# Server
PORT=8000
NODE_ENV=development
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/nexha_commerce_identity

# SUTAR OS Integration (RTMN trust layer)
SUTAR_IDENTITY_URL=http://localhost:4702
SUTAR_REPUTATION_URL=http://localhost:4251
SUTAR_DECISION_URL=http://localhost:4240

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Service-to-service
INTERNAL_API_KEY=change-me-in-production

# Guest onboarding
GUEST_ID_PREFIX=GST-
GUEST_DEFAULT_VALIDITY_DAYS=30
WHATSAPP_VERIFICATION_REQUIRED=true
