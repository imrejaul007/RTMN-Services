# rez-auth-service Environment Configuration
# Copy this file to .env and fill in real values for local dev
# On Render, set these as environment variables in the dashboard

# === Core Service ===
NODE_ENV=production
PORT=4002
HEALTH_PORT=4102
SERVICE_NAME=rez-auth-service
LOG_LEVEL=info

# === Database [REQUIRED] ===
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/rez_auth?retryWrites=true&w=majority

# === Cache [REQUIRED] ===
REDIS_URL=redis://default:PASS@HOST:6379
REDIS_PASSWORD=
REDIS_SENTINEL_HOSTS=
REDIS_SENTINEL_NAME=mymaster

# === Authentication [REQUIRED] ===
# All secrets MUST be at least 32 characters
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-32-plus-char-random-string-for-jwt-signing
JWT_ADMIN_SECRET=replace-with-32-plus-char-random-string-for-admin-jwt
JWT_MERCHANT_SECRET=replace-with-32-plus-char-random-string-for-merchant-jwt
JWT_REFRESH_SECRET=replace-with-32-plus-char-random-string-for-refresh-tokens
JWT_EXPIRES_IN=15m
JWT_EXPIRES_IN_SECONDS=900
JWT_ADMIN_EXPIRES_IN=1h
JWT_MFA_SESSION_SECRET=replace-with-32-plus-char-random-string-for-mfa

# === Internal Service Auth [REQUIRED] ===
# Either set the JSON map or a single shared token
INTERNAL_SERVICE_TOKENS_JSON={"rez-auth-service":"token-for-auth","rez-wallet-service":"token-for-wallet"}
INTERNAL_SERVICE_TOKEN=

# === OTP Service [REQUIRED] ===
OTP_HMAC_SECRET=replace-with-32-plus-char-random-string-for-otp
EXPOSE_DEV_OTP=false

# === TOTP/MFA Encryption [REQUIRED] ===
# AES-256-GCM key for encrypting TOTP secrets at rest in MongoDB
OTP_TOTP_ENCRYPTION_KEY=replace-with-32-plus-char-random-string-for-totp

# === Email Service [OPTIONAL] ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@rez.money
APP_URL=https://rez.money

# === CORS [REQUIRED] ===
CORS_ORIGIN=https://rez.money,https://www.rez.money,https://admin.rez.money

# === Observability [OPTIONAL] ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# === Internal Service URLs [OPTIONAL] ===
MERCHANT_SERVICE_URL=https://rez-merchant-service.onrender.com
