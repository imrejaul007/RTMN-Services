# REZ-qr-unified Environment Configuration
# Copy this file to .env and fill in real values for local dev
# On Render, set these as environment variables in the dashboard

# === Core Service ===
NODE_ENV=production
PORT=4090
SERVICE_NAME=rez-qr-unified

# === Database [REQUIRED] ===
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/rez_qr_unified?retryWrites=true&w=majority

# === CORS ===
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://rez.money,https://admin.rez.money,https://now.rez.money,https://karma.app,https://stayown.app

# === Company Config (JSON-encoded) ===
# Maps company names to their base URLs
COMPANY_CONFIG={"rez":"https://api.rez.money","stayown":"https://api.stayown.app","karma":"https://api.karma.app"}
