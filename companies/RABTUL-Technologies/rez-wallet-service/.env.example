# rez-wallet-service Environment Configuration
# Copy this file to .env and fill in real values for local dev
# On Render, set these as environment variables in the dashboard

# === Core Service ===
NODE_ENV=production
PORT=4004
SERVICE_NAME=rez-wallet-service
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=30000

# === Database [REQUIRED] ===
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/rez_wallet?retryWrites=true&w=majority

# === Cache [REQUIRED] ===
REDIS_URL=redis://default:PASS@HOST:6379
REDIS_PASSWORD=
REDIS_SENTINEL_HOSTS=
REDIS_SENTINEL_NAME=mymaster
REDIS_TLS=false

# === Authentication [REQUIRED] ===
# All secrets MUST be at least 32 characters
JWT_SECRET=replace-with-32-plus-char-random-string-for-jwt-signing
JWT_MERCHANT_SECRET=replace-with-32-plus-char-random-string-for-merchant-jwt

# === Internal Service Auth [REQUIRED] ===
INTERNAL_SERVICE_TOKENS_JSON={"rez-auth-service":"token-for-auth","rez-wallet-service":"token-for-wallet"}
INTERNAL_SERVICE_TOKEN=

# === Wallet Config [OPTIONAL] ===
MERCHANT_WALLET_ENCRYPTION_KEY=replace-with-32-plus-char-random-string-for-wallet-encryption
COIN_TO_RUPEE_RATE=1
REZ_COIN_TO_RUPEE_RATE=1

# === Service Integration ===
ANALYTICS_EVENTS_URL=https://rez-analytics-v2.onrender.com
REZ_PAYMENT_SERVICE_URL=https://rez-payment-service.onrender.com
REZ_MERCHANT_SERVICE_URL=https://rez-merchant-service.onrender.com
REZ_ECONOMIC_ENGINE_URL=https://rez-economic-engine.onrender.com
REE_SERVICE_URL=https://rez-ree-service.onrender.com/api
REE_SERVICE_KEY=replace-with-ree-service-key
MONOLITH_URL=https://api.rez.money

# === CORS [REQUIRED] ===
CORS_ORIGIN=https://rez.money

# === Observability [OPTIONAL] ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
