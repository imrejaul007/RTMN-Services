# rez-profile-service Environment Configuration
# Copy this file to .env and fill in real values for local dev
# On Render, set these as environment variables in the dashboard

# === Core Service ===
NODE_ENV=production
PORT=3000
SERVICE_NAME=rez-profile-service
LOG_LEVEL=info

# === Database [REQUIRED] ===
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/rez_profile?retryWrites=true&w=majority

# === Cache [REQUIRED] ===
REDIS_URL=redis://default:PASS@HOST:6379
REDIS_PASSWORD=
REDIS_TLS=false

# === Authentication ===
JWT_SECRET=replace-with-32-plus-char-random-string-for-jwt-signing

# === Service Integration ===
# Defaults match current Render service names; override if your URLs differ
AUTH_SERVICE_URL=https://rez-auth-service.onrender.com
WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com
REE_SERVICE_URL=https://rez-ree-service.onrender.com/api
REE_SERVICE_KEY=replace-with-ree-service-key

# === CORS ===
# Comma-separated list of allowed origins
CORS_ORIGINS=https://rez.money,https://admin.rez.money,https://merchant.rez.money

# === Trust Proxy ===
# Set to true ONLY when behind a trusted reverse proxy (Cloudflare, AWS ALB)
TRUST_PROXY=false
