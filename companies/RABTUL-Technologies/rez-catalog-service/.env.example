# rez-catalog-service Environment Configuration
# Copy this file to .env and fill in real values for local dev
# On Render, set these as environment variables in the dashboard

# === Core Service ===
NODE_ENV=production
PORT=3005
HEALTH_PORT=0
SERVICE_NAME=rez-catalog-service
LOG_LEVEL=info

# === Database [REQUIRED] ===
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/rez_catalog?retryWrites=true&w=majority
MONGODB_QUERY_TIMEOUT_MS=30000

# === Cache [REQUIRED] ===
REDIS_URL=redis://default:PASS@HOST:6379
REDIS_TLS=false

# === Internal Service Auth [REQUIRED] ===
INTERNAL_SERVICE_TOKENS_JSON={"rez-auth-service":"token-for-auth","rez-catalog-service":"token-for-catalog"}
INTERNAL_SERVICE_TOKEN=

# === CORS [REQUIRED] ===
CORS_ORIGIN=http://localhost:3000

# === Observability [OPTIONAL] ===
SENTRY_DSN=
