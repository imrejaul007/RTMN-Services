# rez-payment-service Environment Configuration
# Copy this file to .env and fill in real values for local dev
# On Render, set these as environment variables in the dashboard

# === Core Service ===
NODE_ENV=production
PORT=4003
HEALTH_PORT=4103
SERVICE_NAME=rez-payment-service
LOG_LEVEL=info

# === Database [REQUIRED] ===
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/rez_payment?retryWrites=true&w=majority

# === Cache [REQUIRED] ===
REDIS_URL=redis://default:PASS@HOST:6379
REDIS_PASSWORD=
REDIS_SENTINEL_HOSTS=
REDIS_SENTINEL_NAME=mymaster

# === Authentication [REQUIRED] ===
# All secrets MUST be at least 32 characters
JWT_SECRET=replace-with-32-plus-char-random-string-for-jwt-signing
JWT_MERCHANT_SECRET=replace-with-32-plus-char-random-string-for-merchant-jwt

# === Internal Service Auth [REQUIRED] ===
INTERNAL_SERVICE_TOKENS_JSON={"rez-auth-service":"token-for-auth","rez-wallet-service":"token-for-wallet","rez-payment-service":"token-for-payment"}
INTERNAL_SERVICE_TOKEN=

# === Razorpay Integration [OPTIONAL but recommended] ===
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret
RAZORPAY_CURRENCY=INR

# === Service Integration ===
WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com
MONOLITH_URL=https://api.rez.money
INTERNAL_WEBHOOK_SECRET=replace-with-32-plus-char-random-string-for-internal-webhooks
NBFC_PARTNER=

# === CORS [REQUIRED] ===
CORS_ORIGIN=https://rez.money

# === Observability [OPTIONAL] ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
