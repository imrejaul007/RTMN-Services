# rez-search-service Environment Configuration
# Copy this file to .env and fill in real values for local dev
# On Render, set these as environment variables in the dashboard

# === Core Service ===
NODE_ENV=production
PORT=3008
SERVICE_NAME=rez-search-service
LOG_LEVEL=info
SERVICE_VERSION=1.0.0

# === Database [REQUIRED] ===
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/rez_search?retryWrites=true&w=majority

# === Cache [REQUIRED] ===
REDIS_URL=redis://default:PASS@HOST:6379
REDIS_PASSWORD=

# === Authentication [REQUIRED] ===
JWT_SECRET=replace-with-32-plus-char-random-string-for-jwt-signing

# === CORS [REQUIRED] ===
CORS_ORIGIN=https://rez.money

# === Trust Proxy ===
TRUST_PROXY=false

# === Observability [OPTIONAL] ===
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# === Elasticsearch (Optional — for advanced search) ===
# If not provided, falls back to MongoDB text search
ELASTICSEARCH_URL=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
