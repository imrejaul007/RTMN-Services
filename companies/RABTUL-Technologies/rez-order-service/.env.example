# rez-order-service Environment Configuration
# Copy this file to .env and fill in real values for local dev
# On Render, set these as environment variables in the dashboard

# === Core Service ===
NODE_ENV=production
PORT=3006
HEALTH_PORT=0
SERVICE_NAME=rez-order-service
LOG_LEVEL=info

# === Database [REQUIRED] ===
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/rez_order?retryWrites=true&w=majority

# === Cache [REQUIRED] ===
REDIS_URL=redis://default:PASS@HOST:6379
REDIS_PASSWORD=
REDIS_SENTINEL_HOSTS=
REDIS_SENTINEL_NAME=mymaster
REDIS_TLS=false

# === Authentication [REQUIRED] ===
# All secrets MUST be at least 32 characters
JWT_SECRET=replace-with-32-plus-char-random-string-for-jwt-signing
JWT_MERCHANT_SECRET=replace-with-32-plus-char-random-string-for-merchant-jwt
JWT_ADMIN_SECRET=replace-with-32-plus-char-random-string-for-admin-jwt

# === Internal Service Auth [REQUIRED] ===
INTERNAL_SERVICE_TOKENS_JSON={"rez-auth-service":"token-for-auth","rez-wallet-service":"token-for-wallet","rez-order-service":"token-for-order"}
INTERNAL_SERVICE_TOKEN=
INTERNAL_SERVICE_HMAC_SECRET=replace-with-32-plus-char-random-string-for-internal-hmac

# === CORS [REQUIRED] ===
CORS_ORIGIN=https://rez.money

# === Observability [OPTIONAL] ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
